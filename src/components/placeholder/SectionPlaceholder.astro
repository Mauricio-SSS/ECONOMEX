---
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  status?: string;
  features?: string[];
  nextSteps?: string[];
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  title,
  description,
  eyebrow = 'Centro Economex',
  status = 'Página en desarrollo',
  features = [],
  nextSteps = [],
  primaryHref = '/articulos',
  primaryLabel = 'Ver artículos',
  secondaryHref = '/',
  secondaryLabel = 'Volver al inicio',
} = Astro.props;
---

<BaseLayout title={`${title} — Centro Economex`} description={description}>
  <section class="interior-hero">
    <div class="container interior-hero__inner">
      <div class="interior-hero__copy">
        <p class="interior-eyebrow">{eyebrow}</p>
        <h1>{title}</h1>
        <p class="interior-hero__description">{description}</p>
        <slot />
      </div>

      <aside class="interior-status" aria-label="Estado de la sección">
        <span>{status}</span>
        <p>
          Esta página forma parte del sistema editorial de Centro Economex. Su contenido final se integrará con publicaciones, bases de datos y componentes interactivos conforme avance la plataforma.
        </p>
      </aside>
    </div>
  </section>

  <section class="interior-body">
    <div class="container interior-body__grid">
      <div class="interior-actions" aria-label="Acciones principales">
        <a href={primaryHref} class="interior-link interior-link--primary">{primaryLabel}<span aria-hidden="true">→</span></a>
        <a href={secondaryHref} class="interior-link">{secondaryLabel}<span aria-hidden="true">→</span></a>
      </div>

      {(features.length > 0 || nextSteps.length > 0) && (
        <div class="interior-panels">
          {features.length > 0 && (
            <section class="interior-panel" aria-labelledby={`${title}-features`}>
              <p class="interior-panel__kicker">Contenido</p>
              <h2 id={`${title}-features`}>Qué tendrá esta sección</h2>
              <ul>
                {features.map((feature) => <li>{feature}</li>)}
              </ul>
            </section>
          )}

          {nextSteps.length > 0 && (
            <section class="interior-panel" aria-labelledby={`${title}-next`}>
              <p class="interior-panel__kicker interior-panel__kicker--red">Desarrollo</p>
              <h2 id={`${title}-next`}>Siguientes pasos</h2>
              <ul>
                {nextSteps.map((step) => <li>{step}</li>)}
              </ul>
            </section>
          )}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .interior-hero {
    background: var(--color-bg-warm);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-ink);
  }

  .interior-hero__inner {
    display: grid;
    gap: clamp(2rem, 6vw, 5rem);
    padding-top: clamp(3rem, 7vw, 6rem);
    padding-bottom: clamp(2.5rem, 6vw, 5rem);
  }

  .interior-hero__copy {
    max-width: 860px;
  }

  .interior-eyebrow,
  .interior-panel__kicker,
  .interior-status span {
    margin: 0;
    color: var(--color-primary);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    line-height: 1;
    text-transform: uppercase;
  }

  .interior-hero h1 {
    max-width: 920px;
    margin: 0.65rem 0 1rem;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(3rem, 8vw, 6.7rem);
    font-weight: 600;
    letter-spacing: -0.055em;
    line-height: 0.9;
    text-wrap: balance;
  }

  .interior-hero__description {
    max-width: 760px;
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: clamp(1.05rem, 2vw, 1.32rem);
    line-height: 1.55;
  }

  .interior-status {
    align-self: end;
    border-top: 2px solid var(--color-ink);
    padding-top: 1.1rem;
  }

  .interior-status p {
    max-width: 42ch;
    margin: 0.85rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.92rem;
    line-height: 1.65;
  }

  .interior-body {
    background: #fff;
    padding: clamp(2rem, 5vw, 4.5rem) 0 clamp(4rem, 8vw, 6rem);
  }

  .interior-body__grid {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
  }

  .interior-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem 1.25rem;
    align-items: center;
  }

  .interior-link {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    border-bottom: 2px solid var(--color-ink);
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
    transition: color var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
  }

  .interior-link--primary {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .interior-link:hover,
  .interior-link:focus-visible {
    color: var(--color-red-700, #c51d23);
    border-color: var(--color-red-700, #c51d23);
    transform: translateY(-2px);
  }

  .interior-panels {
    display: grid;
    border-top: 2px solid var(--color-ink);
  }

  .interior-panel {
    padding: clamp(1.35rem, 3vw, 2rem) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .interior-panel__kicker--red {
    color: var(--color-red-700, #c51d23);
  }

  .interior-panel h2 {
    margin: 0.6rem 0 1rem;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(1.55rem, 3vw, 2.15rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.08;
  }

  .interior-panel ul {
    display: grid;
    gap: 0.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .interior-panel li {
    position: relative;
    padding-left: 1.4rem;
    color: var(--color-text);
    font-size: clamp(0.98rem, 1.4vw, 1.08rem);
    line-height: 1.55;
  }

  .interior-panel li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.72em;
    width: 0.45rem;
    height: 0.45rem;
    background: var(--color-primary);
    transform: translateY(-50%);
  }

  @media (min-width: 920px) {
    .interior-hero__inner {
      grid-template-columns: minmax(0, 1fr) minmax(260px, 380px);
      align-items: end;
    }

    .interior-body__grid {
      grid-template-columns: minmax(220px, 300px) minmax(0, 1fr);
      align-items: start;
    }

    .interior-actions {
      position: sticky;
      top: calc(var(--header-height) + 2rem);
      flex-direction: column;
      align-items: flex-start;
    }

    .interior-panels {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: clamp(2rem, 5vw, 4rem);
    }

    .interior-panel {
      border-bottom: 0;
    }

    .interior-panel + .interior-panel {
      border-left: 1px solid var(--color-border);
      padding-left: clamp(2rem, 5vw, 4rem);
    }
  }
</style>
