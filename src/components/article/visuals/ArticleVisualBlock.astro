---
type VisualItem = {
  label?: string;
  value?: string | number;
  note?: string;
  description?: string;
  year?: string | number;
  title?: string;
};

type Block = {
  type?: string;
  title?: string;
  caption?: string;
  source?: string;
  kicker?: string;
  value?: string;
  label?: string;
  unit?: string;
  highlightLabel?: string;
  lowLabel?: string;
  highLabel?: string;
  leftLabel?: string;
  leftValue?: string;
  rightLabel?: string;
  rightValue?: string;
  text?: string;
  items?: VisualItem[];
  points?: VisualItem[];
  events?: VisualItem[];
};

const { block } = Astro.props as { block: Block };
const type = block.type ?? 'data-card';
const title = block.title ?? 'Visual';
const caption = block.caption;
const source = block.source;

const toNumber = (value: unknown) => {
  if (typeof value === 'number') return Number.isFinite(value) ? value : 0;
  if (typeof value !== 'string') return 0;
  const clean = value.replace(/[^0-9.-]/g, '');
  const parsed = Number.parseFloat(clean);
  return Number.isFinite(parsed) ? parsed : 0;
};

const items = block.items ?? [];
const points = block.points ?? [];
const events = block.events ?? [];
const values = items.map((item) => toNumber(item.value));
const maxValue = Math.max(...values, 1);
const pointValues = points.map((point) => toNumber(point.value));
const minPoint = Math.min(...pointValues, 0);
const maxPoint = Math.max(...pointValues, 1);
const pointRange = Math.max(maxPoint - minPoint, 1);
const chartWidth = 640;
const chartHeight = 260;
const chartPaddingX = 34;
const chartPaddingY = 30;
const linePoints = points.map((point, index) => {
  const denominator = Math.max(points.length - 1, 1);
  const x = chartPaddingX + (index / denominator) * (chartWidth - chartPaddingX * 2);
  const y = chartHeight - chartPaddingY - ((toNumber(point.value) - minPoint) / pointRange) * (chartHeight - chartPaddingY * 2);
  return { ...point, x, y };
});
const polyline = linePoints.map((point) => `${point.x},${point.y}`).join(' ');
---

<figure class={`ce-visual ce-visual--${type}`} data-visual-template={type}>
  <div class="ce-visual__header">
    <p class="ce-visual__kicker">{block.kicker ?? 'Visual Economex'}</p>
    <h3>{title}</h3>
  </div>

  {type === 'data-card' && (
    <div class="ce-visual__data-card">
      <strong>{block.value ?? '0'}</strong>
      <p>{block.label ?? caption}</p>
    </div>
  )}

  {type === 'bar-chart' && (
    <div class="ce-visual__bar-chart" role="img" aria-label={title}>
      {items.map((item) => {
        const value = toNumber(item.value);
        const width = Math.max((value / maxValue) * 100, 2);
        const isHighlight = block.highlightLabel && item.label === block.highlightLabel;
        return (
          <div class={`ce-bar ${isHighlight ? 'is-highlighted' : ''}`} style={`--bar-width: ${width}%`}>
            <div class="ce-bar__label-row">
              <span>{item.label}</span>
              <strong>{item.value}{block.unit ? ` ${block.unit}` : ''}</strong>
            </div>
            <div class="ce-bar__track"><span></span></div>
            {item.note && <p>{item.note}</p>}
          </div>
        );
      })}
    </div>
  )}

  {type === 'line-chart' && (
    <div class="ce-visual__line-chart" role="img" aria-label={title}>
      <svg viewBox={`0 0 ${chartWidth} ${chartHeight}`} preserveAspectRatio="none" aria-hidden="true">
        <line x1={chartPaddingX} y1={chartHeight - chartPaddingY} x2={chartWidth - chartPaddingX} y2={chartHeight - chartPaddingY} class="axis" />
        <line x1={chartPaddingX} y1={chartPaddingY} x2={chartPaddingX} y2={chartHeight - chartPaddingY} class="axis" />
        <polyline points={polyline} class="line" />
        {linePoints.map((point) => <circle cx={point.x} cy={point.y} r="5" class="point" />)}
      </svg>
      <div class="ce-line-points">
        {linePoints.map((point) => (
          <span>
            <strong>{point.label}</strong>
            <em>{point.value}{block.unit ? ` ${block.unit}` : ''}</em>
          </span>
        ))}
      </div>
    </div>
  )}

  {type === 'timeline' && (
    <ol class="ce-visual__timeline">
      {events.map((event) => (
        <li>
          <time>{event.year ?? event.label}</time>
          <div>
            <strong>{event.title}</strong>
            <p>{event.description ?? event.note}</p>
          </div>
        </li>
      ))}
    </ol>
  )}

  {type === 'methodology' && (
    <div class="ce-visual__methodology">
      {block.text && <p>{block.text}</p>}
      {items.length > 0 && (
        <ul>
          {items.map((item) => <li><span>{item.label}</span>{item.description ?? item.note}</li>)}
        </ul>
      )}
    </div>
  )}

  {type === 'comparison' && (
    <div class="ce-visual__comparison">
      <div>
        <span>{block.leftLabel ?? 'Antes'}</span>
        <strong>{block.leftValue ?? '—'}</strong>
      </div>
      <div>
        <span>{block.rightLabel ?? 'Después'}</span>
        <strong>{block.rightValue ?? '—'}</strong>
      </div>
    </div>
  )}

  {type === 'map-index' && (
    <div class="ce-visual__map-index" role="img" aria-label={title}>
      <div class="ce-map-shape" aria-hidden="true">
        <span class="zone zone--one"></span><span class="zone zone--two"></span><span class="zone zone--three"></span><span class="zone zone--four"></span><span class="zone zone--five"></span>
      </div>
      <div class="ce-map-ranking">
        {items.slice(0, 5).map((item) => <p><span>{item.label}</span><strong>{item.value}</strong></p>)}
      </div>
      <div class="ce-map-legend"><span>{block.lowLabel ?? 'Bajo'}</span><i></i><i></i><i></i><span>{block.highLabel ?? 'Alto'}</span></div>
    </div>
  )}

  {(caption || source) && (
    <figcaption>
      {caption}{source && <span> Fuente: {source}</span>}
    </figcaption>
  )}
</figure>

<style>
  .ce-visual {
    border-top: 2px solid var(--color-ink);
    border-bottom: 1px solid var(--color-border);
    margin: clamp(1.6rem, 4vw, 3rem) 0;
    padding: clamp(1rem, 2.8vw, 1.5rem) 0;
    color: var(--color-ink);
  }

  .ce-visual__header {
    display: grid;
    gap: 0.55rem;
    margin-bottom: 1.1rem;
  }

  .ce-visual__kicker {
    margin: 0;
    color: var(--color-red-700, #c51d23);
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.13em;
    line-height: 1;
    text-transform: uppercase;
  }

  .ce-visual h3 {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 3vw, 2.25rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1.08;
    text-transform: none;
  }

  .ce-visual figcaption {
    margin-top: 0.85rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    line-height: 1.5;
  }

  .ce-visual figcaption span {
    color: var(--color-primary);
    font-weight: 750;
  }

  .ce-visual__data-card {
    display: grid;
    gap: 0.75rem;
    border-left: 4px solid var(--color-primary);
    padding-left: clamp(1rem, 2vw, 1.4rem);
  }

  .ce-visual__data-card strong {
    color: var(--color-primary);
    font-family: var(--font-serif);
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 600;
    letter-spacing: -0.07em;
    line-height: 0.9;
  }

  .ce-visual__data-card p {
    max-width: 620px;
    margin: 0;
    color: var(--color-text);
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: 1.55;
  }

  .ce-visual__bar-chart {
    display: grid;
    gap: 0.85rem;
  }

  .ce-bar {
    display: grid;
    gap: 0.35rem;
  }

  .ce-bar__label-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 0.86rem;
    font-weight: 750;
  }

  .ce-bar__label-row strong {
    color: var(--color-primary);
    font-weight: 850;
  }

  .ce-bar__track {
    height: 12px;
    border: 1px solid var(--color-border);
    background: rgba(18, 24, 33, 0.03);
    overflow: hidden;
  }

  .ce-bar__track span {
    display: block;
    width: var(--bar-width);
    height: 100%;
    background: var(--color-primary);
    transition: width 500ms ease;
  }

  .ce-bar.is-highlighted .ce-bar__track span {
    background: var(--color-red-700, #c51d23);
  }

  .ce-bar p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.76rem;
    line-height: 1.4;
  }

  .ce-visual__line-chart {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 0 1rem;
  }

  .ce-visual__line-chart svg {
    width: 100%;
    height: clamp(190px, 34vw, 285px);
    display: block;
  }

  .ce-visual__line-chart .axis {
    stroke: rgba(18, 24, 33, 0.22);
    stroke-width: 1.3;
  }

  .ce-visual__line-chart .line {
    fill: none;
    stroke: var(--color-primary);
    stroke-width: 4;
    stroke-linejoin: round;
    stroke-linecap: round;
  }

  .ce-visual__line-chart .point {
    fill: #fffdfa;
    stroke: var(--color-red-700, #c51d23);
    stroke-width: 3;
  }

  .ce-line-points {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 0.7rem;
  }

  .ce-line-points span {
    border-top: 1px solid var(--color-border);
    padding-top: 0.45rem;
    min-width: 92px;
  }

  .ce-line-points strong,
  .ce-line-points em {
    display: block;
    font-family: var(--font-sans);
    font-style: normal;
  }

  .ce-line-points strong { color: var(--color-text-muted); font-size: 0.7rem; font-weight: 750; }
  .ce-line-points em { color: var(--color-ink); font-size: 0.9rem; font-weight: 850; margin-top: 0.15rem; }

  .ce-visual__timeline {
    display: grid;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ce-visual__timeline li {
    display: grid;
    grid-template-columns: minmax(70px, 0.22fr) 1fr;
    gap: 1rem;
    border-top: 1px solid var(--color-border);
    padding: 1rem 0;
  }

  .ce-visual__timeline time {
    color: var(--color-primary);
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.04em;
  }

  .ce-visual__timeline strong { color: var(--color-ink); font-size: 0.95rem; }
  .ce-visual__timeline p { margin: 0.25rem 0 0; color: var(--color-text-muted); font-size: 0.86rem; line-height: 1.5; }

  .ce-visual__methodology {
    display: grid;
    gap: 1rem;
  }

  .ce-visual__methodology > p {
    margin: 0;
    color: var(--color-text);
    line-height: 1.65;
  }

  .ce-visual__methodology ul {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .ce-visual__methodology li {
    border-top: 1px solid var(--color-border);
    padding: 0.75rem 0;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .ce-visual__methodology li span {
    display: block;
    color: var(--color-ink);
    font-weight: 850;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-size: 0.72rem;
    margin-bottom: 0.25rem;
  }

  .ce-visual__comparison {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .ce-visual__comparison div {
    padding: clamp(1rem, 3vw, 1.45rem) 0;
  }

  .ce-visual__comparison div + div {
    border-left: 1px solid var(--color-border);
    padding-left: clamp(1rem, 3vw, 1.45rem);
  }

  .ce-visual__comparison span,
  .ce-visual__comparison strong {
    display: block;
  }

  .ce-visual__comparison span {
    color: var(--color-text-muted);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .ce-visual__comparison strong {
    color: var(--color-primary);
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3.6rem);
    font-weight: 600;
    letter-spacing: -0.06em;
    line-height: 1;
    margin-top: 0.45rem;
  }

  .ce-visual__map-index {
    display: grid;
    gap: 1.25rem;
  }

  .ce-map-shape {
    position: relative;
    min-height: 230px;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  .zone { position: absolute; display: block; clip-path: polygon(10% 18%, 80% 0, 100% 42%, 72% 100%, 0 76%); border: 1px solid #fffdfa; }
  .zone--one { left: 8%; top: 18%; width: 33%; height: 34%; background: #b7d6c7; }
  .zone--two { left: 34%; top: 10%; width: 35%; height: 38%; background: #7fb49d; }
  .zone--three { left: 12%; top: 50%; width: 38%; height: 40%; background: #2f7e62; }
  .zone--four { left: 50%; top: 44%; width: 40%; height: 40%; background: #0c5f46; }
  .zone--five { right: 5%; top: 22%; width: 33%; height: 36%; background: #c51d23; }

  .ce-map-ranking {
    display: grid;
    gap: 0;
  }

  .ce-map-ranking p {
    display: flex;
    justify-content: space-between;
    border-top: 1px solid var(--color-border);
    margin: 0;
    padding: 0.55rem 0;
    font-size: 0.85rem;
  }

  .ce-map-ranking strong { color: var(--color-primary); }

  .ce-map-legend { display: grid; grid-template-columns: auto repeat(3, 1fr) auto; gap: 0.35rem; align-items: center; }
  .ce-map-legend span { color: var(--color-text-muted); font-size: 0.7rem; font-weight: 750; }
  .ce-map-legend i { height: 10px; background: #b7d6c7; }
  .ce-map-legend i:nth-of-type(2) { background: #2f7e62; }
  .ce-map-legend i:nth-of-type(3) { background: #0c5f46; }

  @media (max-width: 640px) {
    .ce-visual__timeline li,
    .ce-visual__comparison {
      grid-template-columns: 1fr;
    }

    .ce-visual__comparison div + div {
      border-left: 0;
      border-top: 1px solid var(--color-border);
      padding-left: 0;
    }
  }
</style>
