---
const steps = [
  {
    n: '01',
    title: 'Paper académico',
    desc: 'Identificamos investigación rigurosa relevante para México y revisamos sus métodos.',
  },
  {
    n: '02',
    title: 'Traducción simple',
    desc: 'Reescribimos los hallazgos en lenguaje claro, con visualizaciones y contexto local.',
  },
  {
    n: '03',
    title: 'Impacto público',
    desc: 'Distribuimos a tomadores de decisión, prensa y ciudadanía para que la evidencia se use.',
  },
];
---
<section class="section translation" aria-labelledby="translation-title">
  <div class="container">
    <header class="translation__header">
      <span class="eyebrow">Investigación traducida</span>
      <h2 id="translation-title">Del paper original a una explicación clara</h2>
      <p>
        Hacemos accesible la mejor evidencia económica para que sirva más allá de la academia.
      </p>
    </header>

    <ol class="translation__steps">
      {steps.map((step) => (
        <li class="translation__step">
          <span class="translation__num">{step.n}</span>
          <h3 class="translation__title">{step.title}</h3>
          <p class="translation__desc">{step.desc}</p>
        </li>
      ))}
    </ol>

    <div class="translation__cta">
      <a href="/investigacion" class="translation__cta-link">
        Ver últimas traducciones
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14 M13 6l6 6-6 6" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .translation { background: var(--color-bg-warm); }

  .translation__header {
    max-width: 60ch;
    margin: 0 auto var(--space-7);
    text-align: center;
  }
  .translation__header h2 {
    margin: var(--space-2) 0 var(--space-3);
  }
  .translation__header p {
    color: var(--color-text);
    font-size: var(--fs-md);
    margin: 0;
  }

  .translation__steps {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-7);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    counter-reset: step;
  }

  .translation__step {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    position: relative;
  }

  .translation__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--fs-sm);
    color: var(--color-primary);
    background: var(--color-green-100);
    border-radius: var(--radius-full);
    padding: 0.25rem 0.625rem;
    margin-bottom: var(--space-3);
  }
  .translation__title {
    font-family: var(--font-serif);
    font-size: var(--fs-lg);
    color: var(--color-ink);
    margin: 0 0 var(--space-2);
  }
  .translation__desc {
    color: var(--color-text);
    margin: 0;
    font-size: var(--fs-sm);
    line-height: 1.55;
  }

  .translation__cta { text-align: center; }
  .translation__cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--color-primary);
  }
  .translation__cta-link svg { width: 16px; height: 16px; }

  @media (min-width: 768px) {
    .translation__steps {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-5);
    }
  }
</style>
