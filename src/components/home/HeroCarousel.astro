---
interface HeroSlide {
  eyebrow: string;
  title: string;
  summary: string;
  href: string;
  cta: string;
  meta: string;
  image: string;
}

const slides: HeroSlide[] = [
  {
    eyebrow: 'Edición especial',
    title: '¿Por qué crecen distinto los estados de México?',
    summary:
      'Un análisis profundo de productividad, inversión y educación que revela las asimetrías estructurales en el desarrollo regional.',
    href: '/articulos/crecimiento-estados-mexico',
    cta: 'Leer edición completa',
    meta: 'MAYO 2026 • 12 MIN LECTURA',
    image: '/images/hero/mexico-dark.svg',
  },
  {
    eyebrow: 'Gráfico explica',
    title: 'Inflación: lo que muestran los datos más recientes',
    summary:
      'Una lectura visual para entender cómo cambian los precios y qué significa para los hogares mexicanos.',
    href: '/articulos/inflacion-datos-recientes',
    cta: 'Ver análisis visual',
    meta: 'MAYO 2026 • 8 MIN LECTURA',
    image: '/images/hero/mexico-dark.svg',
  },
  {
    eyebrow: 'Investigación traducida',
    title: '¿Qué dice la evidencia sobre la jornada laboral de 4 días?',
    summary:
      'Traducimos hallazgos académicos a lenguaje cotidiano para tomar mejores decisiones de política pública.',
    href: '/articulos/jornada-laboral-4-dias',
    cta: 'Leer investigación',
    meta: 'MAYO 2026 • 10 MIN LECTURA',
    image: '/images/hero/mexico-dark.svg',
  },
];
---

<section class="editorial-hero" aria-roledescription="carrusel" aria-label="Publicaciones destacadas">
  <div class="editorial-hero__track" data-editorial-carousel-track>
    {slides.map((slide, index) => (
      <article
        class="editorial-hero__slide"
        role="group"
        aria-roledescription="diapositiva"
        aria-label={`${index + 1} de ${slides.length}: ${slide.title}`}
        data-editorial-carousel-slide
        style={`--hero-bg: url('${slide.image}')`}
      >
        <div class="editorial-hero__shade" aria-hidden="true"></div>

        <div class="editorial-hero__content">
          <p class="editorial-hero__eyebrow">{slide.eyebrow}</p>

          {index === 0 ? (
            <h1 class="editorial-hero__title">{slide.title}</h1>
          ) : (
            <h2 class="editorial-hero__title">{slide.title}</h2>
          )}

          <p class="editorial-hero__summary">{slide.summary}</p>

          <div class="editorial-hero__cta-row">
            <a class="editorial-hero__button" href={slide.href}>{slide.cta}</a>
            <p class="editorial-hero__meta">{slide.meta}</p>
          </div>
        </div>
      </article>
    ))}
  </div>

  <div class="editorial-hero__pagination" role="tablist" aria-label="Seleccionar publicación destacada">
    {slides.map((slide, index) => (
      <button
        type="button"
        role="tab"
        aria-label={`Mostrar: ${slide.title}`}
        aria-selected={index === 0 ? 'true' : 'false'}
        class={index === 0 ? 'is-active' : ''}
        data-editorial-carousel-dot
        data-index={index}
      />
    ))}
  </div>
</section>

<style>
  .editorial-hero {
    position: relative;
    min-height: calc(100svh - var(--header-height));
    background: #090a0a;
    overflow: hidden;
    isolation: isolate;
  }

  .editorial-hero__track {
    display: flex;
    width: 100%;
    min-height: calc(100svh - var(--header-height));
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .editorial-hero__track::-webkit-scrollbar {
    display: none;
  }

  .editorial-hero__slide {
    position: relative;
    flex: 0 0 100%;
    min-height: calc(100svh - var(--header-height));
    scroll-snap-align: start;
    scroll-snap-stop: always;
    display: flex;
    align-items: center;
    background-image: var(--hero-bg);
    background-size: cover;
    background-position: 50% 50%;
    color: #fff;
  }

  .editorial-hero__shade {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 78% 22%, rgba(255, 255, 255, 0.05), transparent 24%),
      linear-gradient(90deg, rgba(0, 0, 0, 0.83) 0%, rgba(0, 0, 0, 0.72) 34%, rgba(0, 0, 0, 0.48) 70%, rgba(0, 0, 0, 0.30) 100%),
      linear-gradient(180deg, rgba(0, 0, 0, 0.12) 0%, rgba(0, 0, 0, 0.56) 100%);
    z-index: 1;
  }

  .editorial-hero__content {
    position: relative;
    z-index: 2;
    width: min(760px, calc(100% - 2rem));
    margin-left: clamp(1.25rem, 5.1vw, 4.15rem);
    margin-top: clamp(0rem, 3vh, 1.5rem);
  }

  .editorial-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    margin: 0 0 1.55rem;
    padding: 0.24rem 0.72rem;
    border: 1px solid rgba(255, 255, 255, 0.88);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    line-height: 1;
    text-transform: uppercase;
  }

  .editorial-hero__title {
    max-width: 850px;
    margin: 0;
    color: #fff;
    font-family: var(--font-serif);
    font-size: clamp(3.55rem, 5.45vw, 4.38rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.055em;
    text-wrap: balance;
  }

  .editorial-hero__summary {
    max-width: 585px;
    margin: 2.15rem 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-family: var(--font-sans);
    font-size: clamp(1.08rem, 1.62vw, 1.32rem);
    font-weight: 500;
    line-height: 1.48;
    letter-spacing: 0.01em;
  }

  .editorial-hero__cta-row {
    display: flex;
    align-items: center;
    gap: 1.55rem;
    margin-top: 2.1rem;
  }

  .editorial-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 240px;
    min-height: 45px;
    padding: 0 1.25rem;
    background: var(--color-red-700);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .editorial-hero__button:hover {
    background: #a91f23;
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.28);
  }

  .editorial-hero__meta {
    margin: 0;
    color: rgba(255, 255, 255, 0.62);
    font-family: var(--font-sans);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .editorial-hero__pagination {
    position: absolute;
    left: clamp(1.25rem, 5.1vw, 4.15rem);
    bottom: clamp(2rem, 7vh, 4.6rem);
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 0.62rem;
  }

  .editorial-hero__pagination button {
    width: 24px;
    height: 3px;
    padding: 0;
    border-radius: 0;
    background: rgba(255, 255, 255, 0.35);
    transition: width var(--transition-fast), background var(--transition-fast), transform var(--transition-fast);
  }

  .editorial-hero__pagination button.is-active {
    width: 33px;
    background: var(--color-red-700);
  }

  .editorial-hero__pagination button:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 4px;
  }

  @media (max-width: 760px) {
    .editorial-hero,
    .editorial-hero__track,
    .editorial-hero__slide {
      min-height: calc(100svh - var(--header-height));
    }

    .editorial-hero__slide {
      align-items: flex-end;
      background-position: 48% 50%;
    }

    .editorial-hero__shade {
      background:
        linear-gradient(180deg, rgba(0, 0, 0, 0.28) 0%, rgba(0, 0, 0, 0.64) 42%, rgba(0, 0, 0, 0.88) 100%),
        linear-gradient(90deg, rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.38));
    }

    .editorial-hero__content {
      width: calc(100% - 2rem);
      margin: 0 1rem 7rem;
    }

    .editorial-hero__eyebrow {
      margin-bottom: 1rem;
      font-size: 0.68rem;
    }

    .editorial-hero__title {
      max-width: 11ch;
      font-size: clamp(2.65rem, 13vw, 4.2rem);
      line-height: 0.98;
    }

    .editorial-hero__summary {
      margin-top: 1.35rem;
      max-width: 100%;
      font-size: 1rem;
      line-height: 1.55;
    }

    .editorial-hero__cta-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.85rem;
      margin-top: 1.55rem;
    }

    .editorial-hero__button {
      width: min(260px, 100%);
    }

    .editorial-hero__meta {
      font-size: 0.7rem;
    }

    .editorial-hero__pagination {
      left: 1rem;
      bottom: 2.4rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .editorial-hero__track {
      scroll-behavior: auto;
    }

    .editorial-hero__button:hover {
      transform: none;
    }
  }
</style>

<script>
  type EditorialCarousel = {
    root: HTMLElement;
    track: HTMLElement;
    slides: HTMLElement[];
    dots: HTMLButtonElement[];
    current: number;
  };

  function setupEditorialCarousel(root: HTMLElement) {
    const track = root.querySelector<HTMLElement>('[data-editorial-carousel-track]');
    const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-editorial-carousel-slide]'));
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-editorial-carousel-dot]'));

    if (!track || slides.length === 0) return;

    const state: EditorialCarousel = { root, track, slides, dots, current: 0 };
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const setActive = (index: number) => {
      state.current = index;
      dots.forEach((dot, i) => {
        dot.classList.toggle('is-active', i === index);
        dot.setAttribute('aria-selected', i === index ? 'true' : 'false');
      });
    };

    const goTo = (index: number) => {
      const nextIndex = (index + slides.length) % slides.length;
      const slide = slides[nextIndex];
      const left = slide.offsetLeft - track.offsetLeft;
      track.scrollTo({ left, behavior: reduceMotion ? 'auto' : 'smooth' });
      setActive(nextIndex);
    };

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        goTo(Number(dot.dataset.index ?? 0));
      });
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && entry.intersectionRatio >= 0.6) {
            const index = slides.indexOf(entry.target as HTMLElement);
            if (index >= 0) setActive(index);
          }
        });
      },
      { root: track, threshold: [0.6] },
    );

    slides.forEach((slide) => observer.observe(slide));

    root.tabIndex = 0;
    root.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft') {
        event.preventDefault();
        goTo(state.current - 1);
      }

      if (event.key === 'ArrowRight') {
        event.preventDefault();
        goTo(state.current + 1);
      }
    });

    if (!reduceMotion) {
      let timer: number | undefined;
      const stop = () => timer && window.clearInterval(timer);
      const start = () => {
        stop();
        timer = window.setInterval(() => goTo(state.current + 1), 8500);
      };

      root.addEventListener('mouseenter', stop);
      root.addEventListener('mouseleave', start);
      root.addEventListener('focusin', stop);
      root.addEventListener('focusout', start);
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stop();
        else start();
      });

      start();
    }
  }

  document.querySelectorAll<HTMLElement>('.editorial-hero').forEach(setupEditorialCarousel);
</script>
