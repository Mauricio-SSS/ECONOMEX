---
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';
import { featuredArticles } from '../../data/articles';

interface Slide {
  category: string;
  title: string;
  summary: string;
  href: string;
  ctaPrimary: string;
  ctaSecondary?: { label: string; href: string };
  visual: 'map' | 'chart' | 'editorial' | 'tool';
  image?: string;
  meta?: string;
}

const slides: Slide[] = [
  {
    category: featuredArticles[0].category,
    title: featuredArticles[0].title,
    summary: featuredArticles[0].summary,
    href: featuredArticles[0].href,
    ctaPrimary: 'Leer artículo',
    ctaSecondary: { label: 'Explorar datos', href: '/datos/comparador-estatal' },
    visual: 'map',
    meta: `${featuredArticles[0].dateLabel} · ${featuredArticles[0].readingTime}`,
  },
  {
    category: featuredArticles[1].category,
    title: featuredArticles[1].title,
    summary: featuredArticles[1].summary,
    href: featuredArticles[1].href,
    ctaPrimary: 'Ver gráfico',
    visual: 'chart',
    meta: `${featuredArticles[1].dateLabel} · ${featuredArticles[1].readingTime}`,
  },
  {
    category: featuredArticles[2].category,
    title: featuredArticles[2].title,
    summary: featuredArticles[2].summary,
    href: featuredArticles[2].href,
    ctaPrimary: 'Leer traducción',
    visual: 'editorial',
    meta: `${featuredArticles[2].dateLabel} · ${featuredArticles[2].readingTime}`,
  },
  {
    category: featuredArticles[3].category,
    title: featuredArticles[3].title,
    summary: featuredArticles[3].summary,
    href: featuredArticles[3].href,
    ctaPrimary: 'Explorar herramienta',
    visual: 'tool',
    meta: featuredArticles[3].readingTime,
  },
];
---
<section class="hero" aria-roledescription="carrusel" aria-label="Artículos destacados">
  <div class="container">
    <div class="hero__shell" data-carousel>
      <div class="hero__track" data-carousel-track>
        {slides.map((slide, i) => (
          <article
            class="hero__slide"
            role="group"
            aria-roledescription="diapositiva"
            aria-label={`${i + 1} de ${slides.length}: ${slide.title}`}
            data-carousel-slide
          >
            <div class="hero__content">
              <Badge tone={slide.visual === 'editorial' ? 'warm' : slide.visual === 'chart' ? 'red' : 'green'}>
                {slide.category}
              </Badge>
              {i === 0 ? (
                <h1 class="hero__title">{slide.title}</h1>
              ) : (
                <p class="hero__title editorial-title">{slide.title}</p>
              )}
              <p class="hero__summary">{slide.summary}</p>
              {slide.meta && <p class="hero__meta">{slide.meta}</p>}
              <div class="hero__ctas">
                <Button href={slide.href} variant="primary" size="lg">{slide.ctaPrimary}</Button>
                {slide.ctaSecondary && (
                  <Button href={slide.ctaSecondary.href} variant="secondary" size="lg">
                    {slide.ctaSecondary.label}
                  </Button>
                )}
              </div>
            </div>

            <div class={`hero__visual hero__visual--${slide.visual}`} aria-hidden="true">
              {slide.visual === 'map' && (
                <img
                  src="/images/mock-map-mexico.svg"
                  alt=""
                  width="640"
                  height="480"
                  loading={i === 0 ? 'eager' : 'lazy'}
                  fetchpriority={i === 0 ? 'high' : 'auto'}
                  decoding="async"
                />
              )}
              {slide.visual === 'chart' && (
                <img
                  src="/images/mock-chart.svg"
                  alt=""
                  width="640"
                  height="480"
                  loading="lazy"
                  decoding="async"
                />
              )}
              {slide.visual === 'editorial' && (
                <div class="hero__editorial-card">
                  <span class="hero__editorial-eyebrow">Investigación · 2026</span>
                  <span class="hero__editorial-quote">
                    “Reducir la jornada laboral no implica perder productividad cuando se rediseña el trabajo.”
                  </span>
                  <span class="hero__editorial-source">Síntesis de evidencia, OECD &amp; estudios revisados</span>
                </div>
              )}
              {slide.visual === 'tool' && (
                <img
                  src="/images/mock-comparator.svg"
                  alt=""
                  width="640"
                  height="480"
                  loading="lazy"
                  decoding="async"
                />
              )}
            </div>
          </article>
        ))}
      </div>

      <div class="hero__controls">
        <button type="button" class="hero__arrow" aria-label="Anterior" data-carousel-prev>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M15 18l-6-6 6-6" />
          </svg>
        </button>

        <div class="hero__dots" role="tablist" aria-label="Seleccionar diapositiva" data-carousel-dots>
          {slides.map((_, i) => (
            <button
              type="button"
              role="tab"
              aria-label={`Ir a diapositiva ${i + 1}`}
              aria-selected={i === 0 ? 'true' : 'false'}
              data-index={i}
              class={i === 0 ? 'is-active' : ''}
            ></button>
          ))}
        </div>

        <button type="button" class="hero__arrow" aria-label="Siguiente" data-carousel-next>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 6l6 6-6 6" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: var(--space-6);
    padding-bottom: var(--space-10);
    background: linear-gradient(180deg, var(--color-bg-warm) 0%, var(--color-bg) 70%);
  }

  .hero__shell {
    position: relative;
  }

  .hero__track {
    display: flex;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .hero__track::-webkit-scrollbar { display: none; }

  .hero__slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    padding: var(--space-2) 2px;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .hero__title {
    font-family: var(--font-serif);
    color: var(--color-ink);
    font-size: clamp(1.75rem, 5vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0;
    max-width: 18ch;
  }

  .hero__summary {
    font-family: var(--font-sans);
    font-size: var(--fs-md);
    color: var(--color-text);
    margin: 0;
    max-width: 52ch;
    line-height: 1.5;
  }

  .hero__meta {
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    width: 100%;
  }
  .hero__ctas :global(.btn) { flex: 1 1 auto; }

  .hero__visual {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-sm);
  }
  .hero__visual img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1rem;
  }
  .hero__visual--editorial {
    background: var(--color-green-900);
    color: #fff;
    padding: var(--space-6);
    align-items: flex-start;
    text-align: left;
  }
  .hero__editorial-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    color: #fff;
  }
  .hero__editorial-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-green-100);
  }
  .hero__editorial-quote {
    font-family: var(--font-serif);
    font-size: clamp(1.125rem, 2.4vw, 1.5rem);
    font-weight: 600;
    line-height: 1.3;
  }
  .hero__editorial-source {
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    opacity: 0.8;
  }

  .hero__controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }
  .hero__arrow {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-full);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border: 1px solid var(--color-border);
    color: var(--color-ink);
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }
  .hero__arrow:hover {
    border-color: var(--color-ink);
    background: #fff;
  }
  .hero__arrow svg { width: 18px; height: 18px; }

  .hero__dots {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .hero__dots button {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: #D2D6DB;
    transition: width var(--transition-fast), background var(--transition-fast);
  }
  .hero__dots button.is-active {
    width: 28px;
    background: var(--color-primary);
  }

  @media (min-width: 768px) {
    .hero {
      padding-top: var(--space-8);
      padding-bottom: var(--space-12);
    }
    .hero__slide {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
      gap: var(--space-8);
      align-items: center;
      min-height: 480px;
      padding: var(--space-4) 4px;
    }
    .hero__visual {
      aspect-ratio: 4 / 3;
      max-height: 520px;
    }
    .hero__ctas :global(.btn) { flex: 0 0 auto; }
    .hero__controls {
      justify-content: flex-end;
      gap: var(--space-4);
      margin-top: var(--space-6);
    }
    .hero__dots { margin-right: auto; margin-left: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__track { scroll-behavior: auto; }
  }
</style>

<script>
  /**
   * HeroCarousel — vanilla JS, ~1KB minified.
   * Funcionalidad: arrows, dots, teclado (←/→), autoplay opcional.
   * Usa scroll-snap nativo: el navegador hace toda la animación.
   */
  type Carousel = {
    root: HTMLElement;
    track: HTMLElement;
    slides: HTMLElement[];
    dots: HTMLButtonElement[];
    current: number;
  };

  function setup(root: HTMLElement): Carousel | null {
    const track = root.querySelector<HTMLElement>('[data-carousel-track]');
    const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-carousel-slide]'));
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-carousel-dots] button'));
    const prev = root.querySelector<HTMLButtonElement>('[data-carousel-prev]');
    const next = root.querySelector<HTMLButtonElement>('[data-carousel-next]');
    if (!track || slides.length === 0) return null;

    const c: Carousel = { root, track, slides, dots, current: 0 };
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /**
     * Scrollea SOLO el track horizontalmente — nunca la página.
     * scrollIntoView arrastraba la página al cambiar slide cuando el hero
     * estaba parcialmente fuera de viewport.
     */
    const goTo = (idx: number) => {
      const i = (idx + slides.length) % slides.length;
      const slide = slides[i];
      const left = slide.offsetLeft - track.offsetLeft;
      track.scrollTo({ left, behavior: reduceMotion ? 'auto' : 'smooth' });
    };

    prev?.addEventListener('click', () => goTo(c.current - 1));
    next?.addEventListener('click', () => goTo(c.current + 1));
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const idx = Number(dot.dataset.index ?? 0);
        goTo(idx);
      });
    });

    // Sincroniza dots con scroll real (incluye swipe táctil)
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && entry.intersectionRatio >= 0.6) {
            const idx = slides.indexOf(entry.target as HTMLElement);
            if (idx >= 0 && idx !== c.current) {
              c.current = idx;
              dots.forEach((d, i) => {
                d.classList.toggle('is-active', i === idx);
                d.setAttribute('aria-selected', i === idx ? 'true' : 'false');
              });
            }
          }
        });
      },
      { root: track, threshold: [0.6] },
    );
    slides.forEach((s) => observer.observe(s));

    // Teclado cuando el carrusel tiene foco
    root.tabIndex = 0;
    root.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { e.preventDefault(); goTo(c.current - 1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); goTo(c.current + 1); }
    });

    // Autoplay (pausado en hover/focus y si el usuario prefiere reducir motion)
    if (!reduceMotion) {
      let timer: number | undefined;
      const start = () => {
        stop();
        timer = window.setInterval(() => goTo(c.current + 1), 7000);
      };
      const stop = () => { if (timer) window.clearInterval(timer); };
      root.addEventListener('mouseenter', stop);
      root.addEventListener('mouseleave', start);
      root.addEventListener('focusin', stop);
      root.addEventListener('focusout', start);
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stop(); else start();
      });
      start();
    }

    return c;
  }

  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(setup);
</script>
