---
import { policyBriefs } from '../../data/topics';
---
<section class="section briefs" aria-labelledby="briefs-title">
  <div class="container briefs__inner">
    <div class="briefs__intro">
      <span class="eyebrow">Policy briefs</span>
      <h2 id="briefs-title">Recomendaciones cortas, basadas en evidencia</h2>
      <p>
        Documentos breves para tomadores de decisión: qué dice la evidencia y qué hacer con ella.
      </p>
      <a href="/policy-briefs" class="briefs__more">
        Ver todos los policy briefs
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14 M13 6l6 6-6 6" />
        </svg>
      </a>
    </div>

    <ul class="briefs__list">
      {policyBriefs.map((brief) => (
        <li>
          <a class="briefs__item" href={brief.href}>
            <span class="briefs__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 3h7l4 4v14H7z M14 3v4h4 M9 13h6 M9 17h4" />
              </svg>
            </span>
            <span class="briefs__body">
              <span class="briefs__title">{brief.title}</span>
              <span class="briefs__meta">PDF · {brief.pages} pp · {brief.date}</span>
            </span>
            <span class="briefs__action" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3v12 M7 10l5 5 5-5 M5 21h14" />
              </svg>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .briefs__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  .briefs__intro h2 { margin: var(--space-2) 0 var(--space-3); }
  .briefs__intro p {
    color: var(--color-text);
    margin: 0 0 var(--space-4);
  }
  .briefs__more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--color-primary);
  }
  .briefs__more svg { width: 16px; height: 16px; }

  .briefs__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .briefs__item {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5);
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-ink);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }
  .briefs__item:hover {
    border-color: var(--color-red-700);
    box-shadow: var(--shadow-md);
  }
  .briefs__item:hover .briefs__icon {
    background: var(--color-red-100);
    color: var(--color-red-700);
  }

  .briefs__icon {
    width: 44px; height: 44px;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    background: var(--color-bg-warm);
    color: var(--color-ink);
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .briefs__icon svg { width: 22px; height: 22px; }

  .briefs__body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
    min-width: 0;
  }
  .briefs__title {
    font-family: var(--font-serif);
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.3;
    font-size: var(--fs-md);
  }
  .briefs__meta {
    font-family: var(--font-sans);
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .briefs__action {
    color: var(--color-text-muted);
  }
  .briefs__action svg { width: 18px; height: 18px; }

  @media (min-width: 768px) {
    .briefs__inner {
      grid-template-columns: 1fr 1.4fr;
      gap: var(--space-8);
      align-items: start;
    }
  }
</style>
