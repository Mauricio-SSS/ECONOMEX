---
---
<section class="mission" aria-label="Misión de Centro Economex">
  <div class="mission__visual" aria-hidden="true">
    <img
      class="mission__image"
      src="/images/mission/palacio-nacional-uploaded.svg"
      alt=""
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="mission__scrim" aria-hidden="true"></div>

  <div class="container mission__inner">
    <div class="mission__copy">
      <h2>Información rigurosa para mejores decisiones</h2>
      <p>
        Análisis independientes, datos actualizados y perspectivas expertas para
        comprender la economía de México y el mundo.
      </p>
    </div>

    <a class="mission__cta" href="/quienes-somos">
      Conoce nuestro trabajo
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<style>
  .mission {
    position: relative;
    overflow: hidden;
    min-height: clamp(148px, 15vw, 190px);
    background:
      radial-gradient(circle at 8% 48%, rgba(255, 255, 255, 0.05), transparent 16rem),
      linear-gradient(90deg, #052f24 0%, #063f30 48%, #08261f 100%);
    border-top: 1px solid rgba(255, 255, 255, 0.14);
    border-bottom: 1px solid rgba(2, 22, 17, 0.78);
    color: #fff;
  }

  .mission__visual {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 0;
    width: min(64vw, 1120px);
    overflow: hidden;
  }

  .mission__visual::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(90deg,
        #063f30 0%,
        rgba(6, 63, 48, 0.92) 12%,
        rgba(6, 63, 48, 0.52) 31%,
        rgba(6, 63, 48, 0.08) 58%,
        rgba(2, 15, 13, 0.20) 100%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(0, 0, 0, 0.20));
    pointer-events: none;
  }

  .mission__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: right bottom;
    opacity: 1;
    filter: saturate(1.08) contrast(1.08);
  }

  .mission__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(90deg,
        rgba(2, 43, 32, 0.18) 0%,
        rgba(2, 43, 32, 0.08) 42%,
        rgba(2, 20, 17, 0.02) 100%);
    pointer-events: none;
  }

  .mission__inner {
    position: relative;
    z-index: 2;
    display: grid;
    min-height: clamp(148px, 15vw, 190px);
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(1.5rem, 5vw, 5rem);
    padding-top: clamp(1.45rem, 2.6vw, 2.4rem);
    padding-bottom: clamp(1.45rem, 2.6vw, 2.4rem);
  }

  .mission__copy {
    max-width: 880px;
  }

  .mission__copy h2 {
    margin: 0;
    color: #f7f3ea;
    font-family: var(--font-serif);
    font-size: clamp(1.7rem, 2.55vw, 2.45rem);
    font-weight: 600;
    letter-spacing: -0.026em;
    line-height: 1.04;
    text-wrap: balance;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.44);
  }

  .mission__copy p {
    max-width: 820px;
    margin: 0.55rem 0 0;
    color: rgba(247, 243, 234, 0.84);
    font-family: var(--font-sans);
    font-size: clamp(0.9rem, 1.15vw, 1.04rem);
    line-height: 1.48;
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.38);
  }

  .mission__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    min-width: 255px;
    min-height: 48px;
    padding: 0.82rem 1.28rem;
    border: 1px solid rgba(255, 255, 255, 0.66);
    color: #f7f3ea;
    background: rgba(6, 38, 31, 0.26);
    font-family: var(--font-sans);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.18em;
    line-height: 1;
    text-decoration: none;
    text-transform: uppercase;
    transition: background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast), transform var(--transition-fast);
    backdrop-filter: blur(2px);
    box-shadow: 0 10px 34px rgba(0, 0, 0, 0.14);
  }

  .mission__cta span {
    font-size: 1.25rem;
    line-height: 0;
    transform: translateY(-1px);
  }

  .mission__cta:hover,
  .mission__cta:focus-visible {
    background: rgba(255, 255, 255, 0.13);
    border-color: rgba(255, 255, 255, 0.92);
    color: #fff;
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .mission__visual {
      width: 100%;
      opacity: 0.75;
    }

    .mission__visual::before {
      background:
        linear-gradient(90deg, rgba(2, 43, 32, 0.92), rgba(2, 43, 32, 0.56)),
        linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(0, 0, 0, 0.24));
    }

    .mission__inner {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }

    .mission__cta {
      width: fit-content;
    }
  }

  @media (max-width: 640px) {
    .mission {
      min-height: auto;
    }

    .mission__image {
      object-position: 72% bottom;
    }

    .mission__inner {
      min-height: auto;
      padding-top: 1.9rem;
      padding-bottom: 1.9rem;
    }

    .mission__copy h2 {
      font-size: clamp(1.45rem, 7.1vw, 2.05rem);
      line-height: 1.08;
    }

    .mission__copy p {
      font-size: 0.9rem;
    }

    .mission__cta {
      width: 100%;
      min-width: 0;
      min-height: 44px;
      font-size: 0.68rem;
    }
  }
</style>
