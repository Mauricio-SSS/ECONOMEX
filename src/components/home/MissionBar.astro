---
---
<section class="mission" aria-label="Misión de Centro Economex">
  <div class="mission__image" aria-hidden="true"></div>
  <div class="mission__scrim" aria-hidden="true"></div>

  <div class="container mission__inner">
    <div class="mission__copy">
      <h2>Información rigurosa para mejores decisiones</h2>
      <p>
        Análisis independientes, datos actualizados y perspectivas expertas para
        comprender la economía de México y el mundo.
      </p>
    </div>

    <a class="mission__cta" href="/quienes-somos">
      Conoce nuestro trabajo
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<style>
  .mission {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: clamp(118px, 13.2vw, 150px);
    background: #063b2d;
    border-top: 1px solid rgba(255, 255, 255, 0.14);
    border-bottom: 1px solid rgba(2, 22, 17, 0.78);
    color: #fff;
  }

  .mission__image {
    position: absolute;
    inset: 0;
    z-index: -3;
    background-image: url('/images/mission/palacio-nacional-uploaded.svg');
    background-position: right 42% center;
    background-size: cover;
    background-repeat: no-repeat;
    filter: grayscale(0.18) saturate(0.86) contrast(1.08);
    opacity: 0.84;
    transform: scale(1.01);
  }

  .mission__scrim {
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      linear-gradient(90deg,
        rgba(2, 43, 32, 0.98) 0%,
        rgba(2, 43, 32, 0.94) 32%,
        rgba(2, 43, 32, 0.74) 50%,
        rgba(2, 43, 32, 0.28) 70%,
        rgba(2, 20, 17, 0.52) 100%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.07), rgba(0, 0, 0, 0.14));
  }

  .mission::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(circle at 5% 50%, rgba(0, 0, 0, 0.18), transparent 15rem),
      linear-gradient(90deg, rgba(6, 63, 48, 0.72), transparent 54%);
    pointer-events: none;
  }

  .mission__inner {
    display: grid;
    min-height: clamp(118px, 13.2vw, 150px);
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(1.5rem, 5vw, 5rem);
    padding-top: clamp(1.25rem, 2.2vw, 2rem);
    padding-bottom: clamp(1.25rem, 2.2vw, 2rem);
  }

  .mission__copy {
    max-width: 820px;
  }

  .mission__copy h2 {
    margin: 0;
    color: #f7f3ea;
    font-family: var(--font-serif);
    font-size: clamp(1.55rem, 2.1vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.026em;
    line-height: 1.04;
    text-wrap: balance;
  }

  .mission__copy p {
    max-width: 760px;
    margin: 0.48rem 0 0;
    color: rgba(247, 243, 234, 0.78);
    font-family: var(--font-sans);
    font-size: clamp(0.82rem, 1vw, 0.98rem);
    line-height: 1.48;
  }

  .mission__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    min-width: 255px;
    min-height: 46px;
    padding: 0.82rem 1.28rem;
    border: 1px solid rgba(255, 255, 255, 0.52);
    color: #f7f3ea;
    background: rgba(255, 255, 255, 0.045);
    font-family: var(--font-sans);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.18em;
    line-height: 1;
    text-decoration: none;
    text-transform: uppercase;
    transition: background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast), transform var(--transition-fast);
    backdrop-filter: blur(3px);
  }

  .mission__cta span {
    font-size: 1.25rem;
    line-height: 0;
    transform: translateY(-1px);
  }

  .mission__cta:hover,
  .mission__cta:focus-visible {
    background: rgba(255, 255, 255, 0.13);
    border-color: rgba(255, 255, 255, 0.92);
    color: #fff;
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .mission__inner {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }

    .mission__cta {
      width: fit-content;
    }
  }

  @media (max-width: 640px) {
    .mission {
      min-height: auto;
    }

    .mission__image {
      background-position: center right;
      opacity: 0.56;
    }

    .mission__scrim {
      background:
        linear-gradient(90deg, rgba(2, 43, 32, 0.96), rgba(2, 43, 32, 0.78)),
        linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(0, 0, 0, 0.18));
    }

    .mission__inner {
      min-height: auto;
      padding-top: 1.8rem;
      padding-bottom: 1.8rem;
    }

    .mission__copy h2 {
      font-size: clamp(1.45rem, 7.1vw, 2.05rem);
      line-height: 1.08;
    }

    .mission__copy p {
      font-size: 0.9rem;
    }

    .mission__cta {
      width: 100%;
      min-width: 0;
      min-height: 44px;
      font-size: 0.68rem;
    }
  }
</style>
