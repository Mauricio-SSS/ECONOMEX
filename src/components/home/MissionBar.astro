---
---
<section class="mission" aria-label="Misión">
  <div class="container mission__inner">
    <span class="mission__eyebrow">Nuestra misión</span>
    <p class="mission__text">
      Traducimos investigación económica para impulsar decisiones que generen
      <em>bien común</em>.
    </p>
  </div>
</section>

<style>
  .mission {
    background: var(--color-green-900);
    color: #fff;
    padding: var(--space-7) 0;
  }
  .mission__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: flex-start;
  }
  .mission__eyebrow {
    font-family: var(--font-sans);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-green-100);
  }
  .mission__text {
    font-family: var(--font-serif);
    font-size: clamp(1.375rem, 3.2vw, 2rem);
    line-height: 1.25;
    margin: 0;
    max-width: 32ch;
    color: #fff;
    font-weight: 600;
  }
  .mission__text em {
    color: #fff;
    font-style: normal;
    background: linear-gradient(transparent 65%, rgba(255,255,255,0.18) 65%);
    padding: 0 0.15em;
  }
  @media (min-width: 768px) {
    .mission { padding: var(--space-8) 0; }
    .mission__inner { align-items: center; text-align: center; }
    .mission__text { max-width: 40ch; }
  }
</style>
