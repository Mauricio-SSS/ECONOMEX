---
---
<section class="mission" aria-label="Misión de Centro Economex">
  <img
    class="mission__image"
    src="/images/mission/palacio-nacional-uploaded.svg"
    alt=""
    aria-hidden="true"
    loading="lazy"
    decoding="async"
  />
  <div class="mission__scrim" aria-hidden="true"></div>

  <div class="container mission__inner">
    <div class="mission__copy">
      <h2>Información rigurosa para mejores decisiones</h2>
      <p>
        Análisis independientes, datos actualizados y perspectivas expertas para
        comprender la economía de México y el mundo.
      </p>
    </div>

    <a class="mission__cta" href="/quienes-somos">
      Conoce nuestro trabajo
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<style>
  .mission {
    position: relative;
    overflow: hidden;
    min-height: clamp(118px, 13.2vw, 150px);
    background: #063b2d;
    border-top: 1px solid rgba(255, 255, 255, 0.14);
    border-bottom: 1px solid rgba(2, 22, 17, 0.78);
    color: #fff;
  }

  .mission__image {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center right;
    opacity: 1;
    filter: saturate(1.05) contrast(1.04);
    transform: scale(1.01);
  }

  .mission__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(90deg,
        rgba(2, 43, 32, 0.82) 0%,
        rgba(2, 43, 32, 0.70) 34%,
        rgba(2, 43, 32, 0.34) 58%,
        rgba(2, 20, 17, 0.18) 100%),
      radial-gradient(circle at 6% 52%, rgba(0, 0, 0, 0.22), transparent 14rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(0, 0, 0, 0.11));
    pointer-events: none;
  }

  .mission__inner {
    position: relative;
    z-index: 2;
    display: grid;
    min-height: clamp(118px, 13.2vw, 150px);
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(1.5rem, 5vw, 5rem);
    padding-top: clamp(1.25rem, 2.2vw, 2rem);
    padding-bottom: clamp(1.25rem, 2.2vw, 2rem);
  }

  .mission__copy {
    max-width: 820px;
  }

  .mission__copy h2 {
    margin: 0;
    color: #f7f3ea;
    font-family: var(--font-serif);
    font-size: clamp(1.55rem, 2.1vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.026em;
    line-height: 1.04;
    text-wrap: balance;
    text-shadow: 0 1px 18px rgba(0, 0, 0, 0.26);
  }

  .mission__copy p {
    max-width: 760px;
    margin: 0.48rem 0 0;
    color: rgba(247, 243, 234, 0.82);
    font-family: var(--font-sans);
    font-size: clamp(0.82rem, 1vw, 0.98rem);
    line-height: 1.48;
    text-shadow: 0 1px 16px rgba(0, 0, 0, 0.22);
  }

  .mission__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    min-width: 255px;
    min-height: 46px;
    padding: 0.82rem 1.28rem;
    border: 1px solid rgba(255, 255, 255, 0.62);
    color: #f7f3ea;
    background: rgba(255, 255, 255, 0.045);
    font-family: var(--font-sans);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.18em;
    line-height: 1;
    text-decoration: none;
    text-transform: uppercase;
    transition: background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast), transform var(--transition-fast);
    backdrop-filter: blur(3px);
    box-shadow: 0 10px 34px rgba(0, 0, 0, 0.12);
  }

  .mission__cta span {
    font-size: 1.25rem;
    line-height: 0;
    transform: translateY(-1px);
  }

  .mission__cta:hover,
  .mission__cta:focus-visible {
    background: rgba(255, 255, 255, 0.13);
    border-color: rgba(255, 255, 255, 0.92);
    color: #fff;
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .mission__inner {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }

    .mission__cta {
      width: fit-content;
    }
  }

  @media (max-width: 640px) {
    .mission {
      min-height: auto;
    }

    .mission__image {
      object-position: 64% center;
      opacity: 0.95;
    }

    .mission__scrim {
      background:
        linear-gradient(90deg, rgba(2, 43, 32, 0.92), rgba(2, 43, 32, 0.72)),
        linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(0, 0, 0, 0.2));
    }

    .mission__inner {
      min-height: auto;
      padding-top: 1.8rem;
      padding-bottom: 1.8rem;
    }

    .mission__copy h2 {
      font-size: clamp(1.45rem, 7.1vw, 2.05rem);
      line-height: 1.08;
    }

    .mission__copy p {
      font-size: 0.9rem;
    }

    .mission__cta {
      width: 100%;
      min-width: 0;
      min-height: 44px;
      font-size: 0.68rem;
    }
  }
</style>
