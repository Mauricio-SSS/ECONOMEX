---
---
<section class="mission" aria-label="Misión de Centro Economex">
  <img
    class="mission__image"
    src="/images/mission/palacio-nacional-uploaded.svg"
    alt=""
    aria-hidden="true"
    loading="lazy"
    decoding="async"
  />

  <div class="container mission__inner">
    <div class="mission__copy">
      <h2>Información rigurosa para mejores decisiones</h2>
      <p>
        Análisis independientes, datos actualizados y perspectivas expertas para
        comprender la economía de México y el mundo.
      </p>
    </div>

    <a class="mission__cta" href="/quienes-somos">
      Conoce nuestro trabajo
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<style>
  .mission {
    position: relative;
    overflow: hidden;
    min-height: clamp(150px, 15vw, 190px);
    background: #052f24;
    border-top: 1px solid rgba(0, 0, 0, 0.14);
    border-bottom: 1px solid rgba(0, 0, 0, 0.22);
    color: #fff;
  }

  .mission__image {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .mission__inner {
    position: relative;
    z-index: 1;
    display: grid;
    min-height: clamp(150px, 15vw, 190px);
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(1.5rem, 5vw, 5rem);
    padding-top: clamp(1.45rem, 2.6vw, 2.4rem);
    padding-bottom: clamp(1.45rem, 2.6vw, 2.4rem);
  }

  .mission__copy {
    max-width: 900px;
  }

  .mission__copy h2 {
    margin: 0;
    color: #f7f3ea;
    font-family: var(--font-serif);
    font-size: clamp(1.7rem, 2.55vw, 2.45rem);
    font-weight: 600;
    letter-spacing: -0.026em;
    line-height: 1.04;
    text-wrap: balance;
    text-shadow: 0 3px 18px rgba(0, 0, 0, 0.86), 0 1px 2px rgba(0, 0, 0, 0.8);
  }

  .mission__copy p {
    max-width: 820px;
    margin: 0.55rem 0 0;
    color: #f7f3ea;
    font-family: var(--font-sans);
    font-size: clamp(0.9rem, 1.15vw, 1.04rem);
    line-height: 1.48;
    text-shadow: 0 3px 16px rgba(0, 0, 0, 0.86), 0 1px 2px rgba(0, 0, 0, 0.8);
  }

  .mission__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    min-width: 255px;
    min-height: 48px;
    padding: 0.82rem 1.28rem;
    border: 1px solid rgba(255, 255, 255, 0.82);
    color: #f7f3ea;
    background: transparent;
    font-family: var(--font-sans);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.18em;
    line-height: 1;
    text-decoration: none;
    text-transform: uppercase;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.82);
    transition: background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast), transform var(--transition-fast);
  }

  .mission__cta span {
    font-size: 1.25rem;
    line-height: 0;
    transform: translateY(-1px);
  }

  .mission__cta:hover,
  .mission__cta:focus-visible {
    background: rgba(255, 255, 255, 0.1);
    border-color: #fff;
    color: #fff;
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .mission__inner {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }

    .mission__cta {
      width: fit-content;
    }
  }

  @media (max-width: 640px) {
    .mission {
      min-height: auto;
    }

    .mission__image {
      object-position: 68% center;
    }

    .mission__inner {
      min-height: auto;
      padding-top: 1.9rem;
      padding-bottom: 1.9rem;
    }

    .mission__copy h2 {
      font-size: clamp(1.45rem, 7.1vw, 2.05rem);
      line-height: 1.08;
    }

    .mission__copy p {
      font-size: 0.9rem;
    }

    .mission__cta {
      width: 100%;
      min-width: 0;
      min-height: 44px;
      font-size: 0.68rem;
    }
  }
</style>
