---
---
<section class="mission" aria-label="Misión de Centro Economex">
  <div class="mission__bg" aria-hidden="true"></div>
  <div class="container mission__inner">
    <div class="mission__copy">
      <h2>Información rigurosa para mejores decisiones</h2>
      <p>
        Análisis independientes, datos actualizados y perspectivas expertas para
        comprender la economía de México y el mundo.
      </p>
    </div>

    <a class="mission__cta" href="/quienes-somos">
      Conoce nuestro trabajo
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<style>
  .mission {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: clamp(128px, 15vw, 168px);
    background:
      radial-gradient(circle at 12% 50%, rgba(255, 255, 255, 0.08), transparent 24%),
      linear-gradient(90deg, #063f30 0%, #074a37 40%, #0a513d 63%, #10281f 100%);
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    border-bottom: 1px solid rgba(0, 0, 0, 0.28);
    color: #fff;
  }

  .mission::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(90deg, rgba(2, 43, 32, 0.96) 0%, rgba(2, 43, 32, 0.84) 42%, rgba(2, 43, 32, 0.48) 69%, rgba(2, 20, 17, 0.76) 100%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(0, 0, 0, 0.14));
  }

  .mission__bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    background-image: url('/images/mission/palacio-nacional-uploaded.svg');
    background-position: right center;
    background-size: auto 170%;
    background-repeat: no-repeat;
    filter: grayscale(0.18) saturate(0.85) contrast(1.08);
    opacity: 0.58;
  }

  .mission__inner {
    display: grid;
    min-height: clamp(128px, 15vw, 168px);
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(1.5rem, 5vw, 5rem);
    padding-top: clamp(1.55rem, 3vw, 2.6rem);
    padding-bottom: clamp(1.55rem, 3vw, 2.6rem);
  }

  .mission__copy {
    max-width: 760px;
  }

  .mission__copy h2 {
    margin: 0;
    color: #f7f3ea;
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 2.4vw, 2.12rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.05;
    text-wrap: balance;
  }

  .mission__copy p {
    max-width: 720px;
    margin: 0.48rem 0 0;
    color: rgba(247, 243, 234, 0.8);
    font-family: var(--font-sans);
    font-size: clamp(0.78rem, 1.05vw, 0.96rem);
    line-height: 1.55;
  }

  .mission__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    min-width: 245px;
    min-height: 48px;
    padding: 0.85rem 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.56);
    color: #f7f3ea;
    background: rgba(255, 255, 255, 0.03);
    font-family: var(--font-sans);
    font-size: 0.73rem;
    font-weight: 850;
    letter-spacing: 0.16em;
    line-height: 1;
    text-decoration: none;
    text-transform: uppercase;
    transition: background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast), transform var(--transition-fast);
    backdrop-filter: blur(2px);
  }

  .mission__cta span {
    font-size: 1.2rem;
    line-height: 0;
  }

  .mission__cta:hover,
  .mission__cta:focus-visible {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.9);
    color: #fff;
    transform: translateY(-2px);
  }

  @media (max-width: 760px) {
    .mission {
      min-height: auto;
    }

    .mission__bg {
      background-size: cover;
      background-position: center right;
      opacity: 0.38;
    }

    .mission__inner {
      min-height: auto;
      grid-template-columns: 1fr;
      gap: 1.35rem;
      padding-top: 2rem;
      padding-bottom: 2rem;
    }

    .mission__copy h2 {
      font-size: clamp(1.55rem, 7.5vw, 2.2rem);
    }

    .mission__copy p {
      font-size: 0.9rem;
    }

    .mission__cta {
      width: 100%;
      min-width: 0;
      min-height: 46px;
    }
  }
</style>
