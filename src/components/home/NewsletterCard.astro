---
interface Props {
  variant?: 'card' | 'wide';
}
const { variant = 'card' } = Astro.props;
---
<section class={`newsletter newsletter--${variant}`} aria-labelledby="newsletter-title">
  <div class="container newsletter__inner">
    <div class="newsletter__copy">
      <span class="newsletter__eyebrow">Boletín</span>
      <h2 id="newsletter-title">Análisis económico cada semana</h2>
      <p>Reciba lecturas breves, datos y publicaciones nuevas de Centro Economex.</p>
    </div>

    <form class="newsletter__form" action="/newsletter" method="get">
      <div class="newsletter__field-row">
        <label for="nl-email" class="visually-hidden">Correo electrónico</label>
        <input
          id="nl-email"
          type="email"
          name="email"
          placeholder="correo@institución.mx"
          required
          autocomplete="email"
        />
        <button type="submit" class="newsletter__submit">Suscribirse</button>
      </div>
      <p class="newsletter__small">Sin spam. Una entrega cuidada cada semana.</p>
    </form>
  </div>
</section>

<style>
  .newsletter {
    background: var(--color-bg-warm);
    border-top: 2px solid var(--color-ink);
    border-bottom: 1px solid var(--color-border);
    padding: 1.35rem 0 1.45rem;
    color: var(--color-ink);
  }

  .newsletter__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    align-items: center;
  }

  .newsletter__eyebrow {
    display: block;
    margin: 0 0 0.45rem;
    color: var(--color-primary);
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    line-height: 1;
    text-transform: uppercase;
  }

  .newsletter__copy h2 {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(1.55rem, 3vw, 2.15rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.04;
  }

  .newsletter__copy p {
    margin: 0.35rem 0 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: clamp(0.92rem, 1.4vw, 1.05rem);
    line-height: 1.45;
  }

  .newsletter__form {
    display: grid;
    gap: 0.6rem;
  }

  .newsletter__field-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  .newsletter__form input {
    width: 100%;
    min-height: 48px;
    padding: 0.85rem 1rem;
    border: 1px solid rgba(18, 24, 33, 0.24);
    border-radius: 0;
    background: #fffdfa;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 0.98rem;
    outline: none;
  }

  .newsletter__form input::placeholder {
    color: rgba(76, 83, 96, 0.66);
  }

  .newsletter__form input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 1px var(--color-primary);
  }

  .newsletter__submit {
    min-height: 48px;
    padding: 0.85rem 1.45rem;
    border-radius: 0;
    background: var(--color-primary);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.86rem;
    font-weight: 850;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background var(--transition-fast), transform var(--transition-fast);
  }

  .newsletter__submit:hover,
  .newsletter__submit:focus-visible {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
  }

  .newsletter__small {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.01em;
  }

  @media (min-width: 860px) {
    .newsletter__inner {
      grid-template-columns: minmax(0, 1fr) minmax(420px, 0.72fr);
      gap: clamp(2rem, 6vw, 6rem);
    }

    .newsletter__field-row {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 1rem;
    }

    .newsletter__submit {
      min-width: 210px;
    }
  }
</style>
