---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const articulos = (await getCollection('articulos')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('es-MX', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  }).format(date);

const featuredArticle = articulos[0];
const articleRows = articulos.slice(1, 4);

const fallbackRows = [
  {
    data: {
      template: 'finanzas-publicas',
      title: 'Sostenibilidad de la deuda soberana en mercados emergentes',
      oneSentence: 'Evaluamos los riesgos de refinanciamiento en un entorno de tasas altas y menor crecimiento potencial.',
      author: 'Roberto Méndez',
      date: new Date('2026-11-14'),
    },
    id: 'sostenibilidad-deuda',
  },
  {
    data: {
      template: 'tecnologia-economia',
      title: 'Inteligencia Artificial: impacto en el mercado laboral formal',
      oneSentence: 'Nuevos datos sugieren que la automatización está desplazando tareas, no necesariamente empleos completos.',
      author: 'Carlos Ortega',
      date: new Date('2026-11-09'),
    },
    id: 'ia-mercado-laboral',
  },
  {
    data: {
      template: 'politica-monetaria',
      title: 'Hacia una política de metas de inflación flexible',
      oneSentence: 'Propuestas técnicas para moderar marcos de actuación de los bancos centrales ante choques de oferta.',
      author: 'Mariana Torres',
      date: new Date('2026-11-02'),
    },
    id: 'metas-inflacion',
  },
];

const rows = articleRows.length > 0 ? articleRows : fallbackRows;
const featured = featuredArticle ?? {
  data: {
    template: 'investigacion-destacada',
    title: 'La productividad regional y las brechas de crecimiento en México',
    oneSentence: 'Un análisis de largo plazo sobre inversión, educación y capacidad institucional en las entidades federativas.',
    author: 'Dra. Sofía Méndez',
    date: new Date('2026-11-20'),
  },
  id: 'productividad-regional',
};

const getSlug = (article: { id: string }) => article.id.replace(/\.(md|mdx)$/, '');
const visualClasses = ['folds', 'curve', 'light'];
const mostRead = [
  'El futuro del sistema de pensiones: una bomba de tiempo demográfica',
  'Minería y medio ambiente: un balance necesario para el desarrollo',
  'Reformas fiscales pendientes para 2027',
];
const topics = ['Todos los temas', 'Crecimiento económico', 'Finanzas públicas', 'Mercado laboral', 'Política monetaria'];
---

<BaseLayout
  title="Artículos — Centro Economex"
  description="Análisis, investigación traducida, policy briefs y visualizaciones de Centro Economex."
>
  <main class="articles-page">
    <section class="articles-hero">
      <div class="container">
        <header class="articles-header">
          <div>
            <p class="articles-eyebrow">Publicaciones</p>
            <h1>Artículos</h1>
          </div>
          <p>
            Análisis económico, investigación traducida y datos explicados con claridad para entender los retos públicos de México.
          </p>
        </header>

        <nav class="topic-nav" aria-label="Temas de artículos">
          {topics.map((topic) => <a href="#archivo">{topic}</a>)}
        </nav>
      </div>
    </section>

    <section class="articles-feature" aria-labelledby="featured-article-title">
      <div class="container articles-feature__grid">
        <a class="feature-visual" href={`/articulos/${getSlug(featured)}`} aria-label={`Leer ${featured.data.title}`}>
          <span class="feature-visual__line" aria-hidden="true"></span>
        </a>

        <article class="feature-copy">
          <p class="articles-kicker articles-kicker--red">{featured.data.template.replaceAll('-', ' ')}</p>
          <h2 id="featured-article-title">
            <a href={`/articulos/${getSlug(featured)}`}>{featured.data.title}</a>
          </h2>
          <p>{featured.data.oneSentence}</p>

          <footer class="feature-author">
            <span class="feature-author__mark">CE</span>
            <div>
              <strong>{featured.data.author}</strong>
              <span>{formatDate(featured.data.date)}</span>
            </div>
          </footer>
        </article>
      </div>
    </section>

    <section class="articles-archive" id="archivo" aria-labelledby="archive-title">
      <div class="container articles-archive__layout">
        <div class="articles-list">
          <div class="archive-heading">
            <p class="articles-kicker">Archivo reciente</p>
            <h2 id="archive-title">Últimos artículos</h2>
          </div>

          {rows.map((item, index) => (
            <article class="article-row">
              <a class={`article-thumb article-thumb--${visualClasses[index % visualClasses.length]}`} href={`/articulos/${getSlug(item)}`} aria-label={`Leer ${item.data.title}`}>
                <span aria-hidden="true"></span>
              </a>
              <div class="article-row__content">
                <p class="articles-kicker">{item.data.template.replaceAll('-', ' ')}</p>
                <h3><a href={`/articulos/${getSlug(item)}`}>{item.data.title}</a></h3>
                <p>{item.data.oneSentence}</p>
                <div class="articles-meta">
                  <span>Por {item.data.author}</span>
                  <time datetime={item.data.date.toISOString()}>{formatDate(item.data.date)}</time>
                </div>
              </div>
            </article>
          ))}

          <a class="load-more" href="/articulos">Cargar más artículos</a>
        </div>

        <aside class="articles-sidebar" aria-label="Lecturas recomendadas">
          <section class="most-read">
            <h2>Lo más leído</h2>
            <ol>
              {mostRead.map((item) => (
                <li>
                  <a href="/articulos">{item}</a>
                </li>
              ))}
            </ol>
          </section>

          <section class="articles-newsletter">
            <p class="articles-kicker">Boletín semanal</p>
            <h2>Análisis de fondo, directo en su bandeja de entrada.</h2>
            <form action="/newsletter" method="get">
              <label class="visually-hidden" for="articles-email">Correo electrónico</label>
              <input id="articles-email" type="email" name="email" placeholder="Correo electrónico" autocomplete="email" required />
              <button type="submit">Suscribirse</button>
            </form>
            <p>Al suscribirse, acepta recibir análisis y publicaciones de Centro Economex.</p>
          </section>
        </aside>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .articles-page {
    background: #fff;
    color: var(--color-ink);
  }

  .articles-hero {
    background: var(--color-bg-warm);
    padding: clamp(2.8rem, 6vw, 5.25rem) 0 0;
  }

  .articles-header {
    display: grid;
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: end;
    border-bottom: 2px solid var(--color-ink);
    padding-bottom: clamp(1.25rem, 3vw, 2rem);
  }

  .articles-eyebrow,
  .articles-kicker {
    margin: 0;
    color: var(--color-primary);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    line-height: 1;
    text-transform: uppercase;
  }

  .articles-kicker--red {
    color: var(--color-red-700, #c51d23);
  }

  .articles-header h1 {
    margin: 0.55rem 0 0;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(3.2rem, 8vw, 6.8rem);
    font-weight: 600;
    letter-spacing: -0.058em;
    line-height: 0.9;
  }

  .articles-header > p {
    max-width: 620px;
    margin: 0;
    color: var(--color-text);
    font-size: clamp(1rem, 1.7vw, 1.18rem);
    line-height: 1.6;
  }

  .topic-nav {
    display: flex;
    gap: clamp(1rem, 3vw, 2.25rem);
    overflow-x: auto;
    border-bottom: 1px solid var(--color-border);
    padding: 0.95rem 0;
    scrollbar-width: none;
  }

  .topic-nav::-webkit-scrollbar {
    display: none;
  }

  .topic-nav a {
    flex: 0 0 auto;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
    transition: color var(--transition-fast), transform var(--transition-fast);
  }

  .topic-nav a:first-child,
  .topic-nav a:hover {
    color: var(--color-ink);
    transform: translateY(-1px);
  }

  .articles-feature {
    background: var(--color-bg-warm);
    padding: clamp(1.5rem, 4vw, 3rem) 0 clamp(2.5rem, 5vw, 4rem);
  }

  .articles-feature__grid {
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: stretch;
  }

  .feature-visual {
    position: relative;
    min-height: clamp(220px, 35vw, 390px);
    overflow: hidden;
    background:
      radial-gradient(circle at 77% 50%, rgba(255,255,255,0.92) 0 13%, rgba(98,101,101,0.76) 14%, rgba(18,20,22,0.18) 32%, transparent 33%),
      radial-gradient(circle at 35% 40%, rgba(255,255,255,0.08), transparent 23rem),
      linear-gradient(120deg, #0c0f11 0%, #17191c 54%, #2d3033 100%);
    border: 1px solid rgba(18, 24, 33, 0.18);
  }

  .feature-visual::after {
    content: '';
    position: absolute;
    inset: auto 0 22% 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 8%, rgba(247,243,234,0.8) 36%, transparent 68%);
    transform: rotate(8deg);
  }

  .feature-visual__line {
    position: absolute;
    left: 4%;
    right: 40%;
    top: 52%;
    height: 1px;
    background: rgba(247, 243, 234, 0.55);
    transform: rotate(-7deg);
  }

  .feature-copy {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: center;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }

  .feature-copy h2 {
    max-width: 620px;
    margin: 0.65rem 0 1rem;
    font-family: var(--font-serif);
    font-size: clamp(2.1rem, 4.4vw, 4.15rem);
    font-weight: 600;
    letter-spacing: -0.055em;
    line-height: 0.98;
    text-wrap: balance;
  }

  .feature-copy h2 a {
    color: var(--color-ink);
    text-decoration: none;
  }

  .feature-copy h2 a:hover {
    color: var(--color-primary);
  }

  .feature-copy > p:not(.articles-kicker) {
    max-width: 540px;
    margin: 0;
    color: var(--color-text);
    line-height: 1.6;
  }

  .feature-author {
    display: flex;
    gap: 0.85rem;
    align-items: center;
    border-top: 1px solid var(--color-border);
    margin-top: clamp(1.5rem, 3vw, 2rem);
    padding-top: 1rem;
  }

  .feature-author__mark {
    display: inline-flex;
    width: 38px;
    height: 38px;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.08em;
  }

  .feature-author strong,
  .feature-author span {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.76rem;
  }

  .feature-author strong {
    color: var(--color-ink);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .feature-author span {
    color: var(--color-text-muted);
    margin-top: 0.18rem;
  }

  .articles-archive {
    padding: clamp(2.5rem, 5vw, 4rem) 0 clamp(4rem, 8vw, 6rem);
  }

  .articles-archive__layout {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
  }

  .archive-heading {
    border-bottom: 2px solid var(--color-ink);
    padding-bottom: 0.9rem;
    margin-bottom: 0.2rem;
  }

  .archive-heading h2 {
    margin: 0.45rem 0 0;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 3.5vw, 2.75rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1.04;
  }

  .articles-list {
    display: grid;
  }

  .article-row {
    display: grid;
    gap: clamp(1rem, 3vw, 1.6rem);
    border-bottom: 1px solid var(--color-border);
    padding: clamp(1.25rem, 3vw, 2rem) 0;
  }

  .article-thumb {
    position: relative;
    min-height: 150px;
    overflow: hidden;
    background: #111417;
  }

  .article-thumb--folds {
    background:
      repeating-radial-gradient(ellipse at 30% 20%, rgba(255,255,255,0.16) 0 1px, transparent 2px 16px),
      linear-gradient(135deg, #111417, #3d4041 62%, #111417);
  }

  .article-thumb--curve {
    background:
      radial-gradient(circle at 85% 18%, rgba(255,255,255,0.5), transparent 18%),
      radial-gradient(circle at 85% 55%, rgba(255,255,255,0.22), transparent 25%),
      linear-gradient(135deg, #111417, #3a3d40);
  }

  .article-thumb--light {
    background:
      linear-gradient(130deg, transparent 0 35%, rgba(255,255,255,0.88) 43%, transparent 54%),
      linear-gradient(135deg, #181b1e, #4d5050);
  }

  .article-row__content h3 {
    max-width: 640px;
    margin: 0.42rem 0 0.55rem;
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 2.6vw, 2.15rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.08;
  }

  .article-row__content h3 a {
    color: var(--color-ink);
    text-decoration: none;
  }

  .article-row__content h3 a:hover {
    color: var(--color-primary);
  }

  .article-row__content > p:not(.articles-kicker) {
    max-width: 610px;
    margin: 0;
    color: var(--color-text);
    font-size: 0.96rem;
    line-height: 1.55;
  }

  .articles-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .load-more {
    justify-self: start;
    margin-top: 2.25rem;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-ink);
    padding: 0.85rem 1.4rem;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
    transition: background var(--transition-fast), color var(--transition-fast), transform var(--transition-fast);
  }

  .load-more:hover {
    background: var(--color-ink);
    color: #fff;
    transform: translateY(-2px);
  }

  .articles-sidebar {
    display: grid;
    gap: 1.5rem;
    align-content: start;
  }

  .most-read {
    background: #eef2f4;
    border: 1px solid var(--color-border);
    padding: clamp(1.2rem, 3vw, 1.6rem);
  }

  .most-read h2,
  .articles-newsletter h2 {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .most-read ol {
    display: grid;
    gap: 1.05rem;
    list-style: none;
    counter-reset: most-read;
    margin: 1.2rem 0 0;
    padding: 0;
  }

  .most-read li {
    counter-increment: most-read;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.8rem;
    border-top: 1px solid rgba(18, 24, 33, 0.12);
    padding-top: 0.9rem;
  }

  .most-read li::before {
    content: counter(most-read, decimal-leading-zero);
    color: rgba(18, 24, 33, 0.38);
    font-family: var(--font-serif);
    font-size: 1.35rem;
    line-height: 1;
  }

  .most-read a {
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.18;
    text-decoration: none;
  }

  .most-read a:hover {
    color: var(--color-primary);
  }

  .articles-newsletter {
    background: var(--color-primary);
    color: #fff;
    padding: clamp(1.2rem, 3vw, 1.6rem);
  }

  .articles-newsletter .articles-kicker {
    color: #fff;
  }

  .articles-newsletter h2 {
    color: #fff;
    margin-top: 0.65rem;
  }

  .articles-newsletter form {
    display: grid;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .articles-newsletter input {
    min-height: 42px;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 0;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    padding: 0.75rem;
  }

  .articles-newsletter input::placeholder {
    color: rgba(255, 255, 255, 0.68);
  }

  .articles-newsletter button {
    min-height: 42px;
    background: #fff;
    color: var(--color-primary);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .articles-newsletter > p:last-child {
    margin: 0.9rem 0 0;
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.72rem;
    line-height: 1.5;
  }

  @media (min-width: 860px) {
    .articles-header {
      grid-template-columns: minmax(0, 1fr) minmax(320px, 0.55fr);
    }

    .articles-feature__grid {
      grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.92fr);
    }

    .article-row {
      grid-template-columns: minmax(150px, 240px) minmax(0, 1fr);
    }
  }

  @media (min-width: 1080px) {
    .articles-archive__layout {
      grid-template-columns: minmax(0, 1fr) 320px;
      align-items: start;
    }

    .articles-sidebar {
      position: sticky;
      top: calc(var(--header-height) + 2rem);
    }
  }

  @media (max-width: 640px) {
    .topic-nav {
      margin-inline: calc(var(--container-padding) * -1);
      padding-left: var(--container-padding);
      padding-right: var(--container-padding);
    }
  }
</style>
