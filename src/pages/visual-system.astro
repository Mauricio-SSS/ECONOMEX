---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleVisualBlock from '../components/article/visuals/ArticleVisualBlock.astro';

const templates = [
  { id: 'data-card', label: 'Dato destacado', description: 'Convierte una cifra central en un momento editorial fuerte.', block: { type: 'data-card', kicker: 'Brecha estructural', title: 'La diferencia regional sigue siendo el punto de partida', value: '3.6x', label: 'diferencia aproximada entre entidad líder y rezagada.', caption: 'Use este módulo cuando una cifra resuma el argumento central.', source: 'Centro Economex' } },
  { id: 'bar-chart', label: 'Ranking / barras', description: 'Compara entidades, sectores o indicadores.', block: { type: 'bar-chart', kicker: 'Comparativo', title: 'Productividad laboral por entidad seleccionada', unit: 'pts', highlightLabel: 'Nuevo León', caption: 'El elemento destacado se marca en rojo institucional.', source: 'Serie demostrativa', items: [{ label: 'CDMX', value: '100' }, { label: 'Nuevo León', value: '86' }, { label: 'Jalisco', value: '72' }, { label: 'Querétaro', value: '68' }, { label: 'Chiapas', value: '31' }] } },
  { id: 'line-chart', label: 'Serie de tiempo / línea', description: 'Explica trayectorias históricas y tendencias.', block: { type: 'line-chart', kicker: 'Evolución', title: 'Índice de inversión pública real', unit: 'pts', caption: 'La línea se calcula con los puntos capturados.', source: 'Serie demostrativa', points: [{ label: '2018', value: '74' }, { label: '2019', value: '78' }, { label: '2020', value: '66' }, { label: '2021', value: '71' }, { label: '2022', value: '83' }, { label: '2023', value: '88' }] } },
  { id: 'map-index', label: 'Mapa índice', description: 'Da una lectura territorial con ranking lateral.', block: { type: 'map-index', kicker: 'Territorio', title: 'Índice sintético de desarrollo regional', lowLabel: 'Bajo', highLabel: 'Alto', caption: 'Plantilla editorial de mapa índice.', source: 'Plantilla Economex', items: [{ label: 'Norte industrial', value: '82' }, { label: 'Bajío', value: '76' }, { label: 'Centro', value: '69' }, { label: 'Sur-sureste', value: '44' }, { label: 'Frontera sur', value: '38' }] } },
  { id: 'timeline', label: 'Línea de tiempo', description: 'Organiza reformas, crisis y cambios institucionales.', block: { type: 'timeline', kicker: 'Secuencia', title: 'Momentos clave de política regional', caption: 'Ideal para artículos históricos.', source: 'Archivo Economex', events: [{ year: '1994', title: 'Apertura comercial', description: 'La integración exportadora reordena la geografía productiva.' }, { year: '2008', title: 'Crisis financiera', description: 'El choque externo afecta regiones con distinta intensidad.' }, { year: '2020', title: 'Choque pandémico', description: 'Servicios, manufacturas y empleo informal divergen.' }] } },
  { id: 'comparison', label: 'Comparación', description: 'Contrasta dos escenarios, periodos o regiones.', block: { type: 'comparison', kicker: 'Escenarios', title: 'Cambio estimado en capacidad productiva', leftLabel: 'Base', leftValue: '42 pts', rightLabel: 'Con inversión', rightValue: '61 pts', caption: 'Para explicar diferencias entre escenarios.', source: 'Modelo ilustrativo' } },
  { id: 'methodology', label: 'Nota metodológica', description: 'Hace transparente el origen de datos y supuestos.', block: { type: 'methodology', kicker: 'Metodología', title: 'Cómo construimos el índice', text: 'Resume variables, fuentes y criterios de lectura sin interrumpir el flujo editorial.', caption: 'Recomendado para piezas con datos.', source: 'Centro Economex', items: [{ label: 'Productividad', description: 'PIB por trabajador y composición sectorial.' }, { label: 'Capital humano', description: 'Escolaridad y educación técnica.' }, { label: 'Inversión', description: 'Capital, infraestructura y gasto público.' }] } },
];
---

<BaseLayout title="Sistema visual editorial — Centro Economex" description="Biblioteca interna de plantillas visuales reutilizables para artículos.">
  <main class="visual-system-page">
    <section class="vs-hero container">
      <p class="vs-kicker">Biblioteca editorial</p>
      <h1>Sistema visual de Centro Economex</h1>
      <p>Plantillas reutilizables para construir artículos con ritmo editorial: párrafo, visual, párrafo, visual.</p>
      <div class="vs-actions"><a href="/admin/#/collections/articulos/new">Crear artículo en Decap</a><a href="#templates">Ver plantillas</a></div>
    </section>

    <section class="vs-guide container">
      <div><p class="vs-kicker vs-kicker--green">Cómo usarlo</p><h2>Dónde aparecen en Decap</h2></div>
      <ol><li><strong>Abra Decap</strong><span>/admin -> Artículos -> Crear o editar artículo.</span></li><li><strong>Use bloques</strong><span>Cuerpo del artículo por bloques -> Agregar elemento.</span></li><li><strong>Elija visual</strong><span>Visual reutilizable -> Tipo de visual.</span></li><li><strong>Reordene</strong><span>Arrastre bloques para alternar párrafo, visual, párrafo, visual.</span></li></ol>
    </section>

    <section class="vs-index container">
      <p class="vs-kicker vs-kicker--green">Índice</p><h2>Plantillas disponibles</h2>
      <div>{templates.map((template) => <a href={`#${template.id}`}><span>{template.label}</span><em>{template.description}</em></a>)}</div>
    </section>

    <section id="templates" class="vs-library container">
      {templates.map((template) => <article id={template.id} class="vs-card"><header><p class="vs-kicker">{template.label}</p><h2>{template.block.title}</h2><p>{template.description}</p><code>Decap: Artículos / Cuerpo del artículo por bloques / Visual reutilizable</code></header><ArticleVisualBlock block={template.block} /></article>)}
    </section>
  </main>
</BaseLayout>

<style>
.visual-system-page{background:#fffdfa;color:var(--color-ink);padding:clamp(2rem,5vw,4.5rem) 0 clamp(4rem,8vw,7rem)}.vs-hero{border-top:2px solid var(--color-ink);padding-top:1.2rem}.vs-kicker{display:inline-flex;margin:0;color:#f7f3ea;background:var(--color-primary);padding:.36rem .72rem;font-family:var(--font-sans);font-size:.68rem;font-weight:850;letter-spacing:.14em;text-transform:uppercase}.vs-kicker--green{background:transparent;color:var(--color-primary);padding:0}.vs-hero h1{max-width:980px;margin:1rem 0 1.1rem;font-family:var(--font-serif);font-size:clamp(3rem,6.8vw,6.6rem);font-weight:600;letter-spacing:-.065em;line-height:.94}.vs-hero>p{max-width:760px;margin:0;color:#3f454d;font-family:var(--font-serif);font-size:clamp(1.15rem,2vw,1.55rem);font-style:italic}.vs-actions{display:flex;flex-wrap:wrap;gap:.8rem;border-top:1px solid var(--color-border);border-bottom:1px solid var(--color-border);margin-top:2rem;padding:1rem 0}.vs-actions a{border:1px solid var(--color-primary);color:var(--color-primary);padding:.72rem 1rem;font-size:.72rem;font-weight:850;letter-spacing:.1em;text-decoration:none;text-transform:uppercase}.vs-actions a:first-child{background:var(--color-primary);color:#f7f3ea}.vs-guide,.vs-index,.vs-card{border-top:2px solid var(--color-ink);border-bottom:1px solid var(--color-border)}.vs-guide{display:grid;gap:2rem;margin-top:4rem;padding:1.4rem 0}.vs-guide h2,.vs-index h2,.vs-card h2{margin:.6rem 0 0;font-family:var(--font-serif);font-size:clamp(1.8rem,3.8vw,3.4rem);font-weight:600;letter-spacing:-.045em;line-height:1.05}.vs-guide ol{display:grid;margin:0;padding:0;list-style:none}.vs-guide li{display:grid;gap:.35rem;border-top:1px solid var(--color-border);padding:.9rem 0}.vs-guide strong{color:var(--color-primary);font-family:var(--font-serif);font-size:1.35rem}.vs-guide span,.vs-card header>p,.vs-index em{color:var(--color-text-muted);line-height:1.5}.vs-index{margin-top:3rem;padding:1.3rem 0}.vs-index>div{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));margin-top:1.1rem;border-bottom:1px solid var(--color-border)}.vs-index a{display:grid;gap:.3rem;border-top:1px solid var(--color-border);padding:.85rem 1rem .85rem 0;color:var(--color-ink);text-decoration:none}.vs-index a:nth-child(even){border-left:1px solid var(--color-border);padding-left:1rem}.vs-index span{font-size:.78rem;font-weight:850;letter-spacing:.1em;text-transform:uppercase}.vs-index em{font-size:.9rem;font-style:normal}.vs-library{display:grid;gap:3rem;margin-top:3.5rem}.vs-card{display:grid;grid-template-columns:minmax(240px,.36fr) minmax(0,1fr);gap:3rem;align-items:start;padding:1.6rem 0;scroll-margin-top:calc(var(--header-height) + 1.5rem)}.vs-card header{position:sticky;top:calc(var(--header-height) + 1.5rem)}.vs-card code{display:block;border-top:1px solid var(--color-border);margin-top:1.2rem;padding-top:.85rem;color:var(--color-primary);font-size:.72rem;font-weight:750;line-height:1.55;white-space:normal}.vs-card :global(.ce-visual){margin:0}@media(min-width:900px){.vs-guide{grid-template-columns:minmax(260px,.36fr) minmax(0,1fr)}}@media(max-width:860px){.vs-index>div,.vs-card{grid-template-columns:1fr}.vs-index a:nth-child(even){border-left:0;padding-left:0}.vs-card header{position:static}}
</style>
