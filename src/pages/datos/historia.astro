---
import BaseLayout from '../../layouts/BaseLayout.astro';

const features = ['Líneas del tiempo', 'Contexto histórico', 'Gráficas comparativas'];
const nextSteps = [
  'Seleccionar series históricas clave.',
  'Documentar fuentes y cambios metodológicos.',
  'Crear explicadores visuales.',
];

const publications = [
  {
    period: 'Infraestructura · 1920-1950',
    title: 'El Milagro Mexicano: visualizando el crecimiento industrial',
    description:
      'Series históricas sobre producción, urbanización, inversión pública y expansión manufacturera durante la industrialización acelerada.',
    status: 'Próximamente',
    visual: 'city',
  },
  {
    period: 'Finanzas públicas · 1821-1910',
    title: 'Deuda, ingresos y construcción del Estado mexicano',
    description:
      'Una lectura visual de las tensiones fiscales desde la independencia hasta la consolidación institucional del Porfiriato.',
    status: 'En edición',
    visual: 'ledger',
  },
  {
    period: 'Comercio exterior · 1994-2026',
    title: 'Apertura comercial y transformación productiva regional',
    description:
      'Exportaciones, manufactura, empleo formal y cambios regionales desde la integración comercial de América del Norte.',
    status: 'Base de datos',
    visual: 'lines',
  },
  {
    period: 'Moneda y precios · 1900-2026',
    title: 'Inflación, crisis y estabilidad monetaria en México',
    description:
      'Cronología de episodios inflacionarios, choques cambiarios, estabilización macroeconómica y cambios de régimen monetario.',
    status: 'Próximamente',
    visual: 'bars',
  },
];
---

<BaseLayout
  title="Historia — Centro Economex"
  description="Series históricas y contexto económico para entender cómo llegamos a los problemas actuales."
>
  <main class="institutional-page historia-page">
    <section class="institutional-hero" aria-labelledby="institutional-title">
      <div class="container institutional-hero__grid">
        <div class="institutional-hero__copy">
          <p class="institutional-kicker">Datos</p>
          <h1 id="institutional-title">Historia</h1>
          <p class="institutional-dek">
            Series históricas y contexto económico para entender cómo llegamos a los problemas actuales.
          </p>
        </div>

        <aside class="institutional-status" aria-label="Estado de la sección">
          <p class="institutional-status__label">Sección en desarrollo</p>
          <p>
            Esta sección se está consolidando dentro del sistema editorial de Centro Economex como un archivo de datos, briefs visuales y explicadores históricos sobre la economía mexicana.
          </p>
        </aside>
      </div>
    </section>

    <section class="institutional-actions" aria-label="Acciones principales">
      <div class="container institutional-actions__inner">
        <a href="#publicaciones-historia" class="institutional-action institutional-action--primary">Ver publicaciones<span aria-hidden="true">→</span></a>
        <a href="/" class="institutional-action">Volver al inicio<span aria-hidden="true">→</span></a>
      </div>
    </section>

    <section class="institutional-body" aria-label="Contenido de la sección">
      <div class="container institutional-body__grid">
        <div class="institutional-body__intro">
          <p class="institutional-kicker institutional-kicker--green">Arquitectura editorial</p>
          <h2>Qué contendrá esta página</h2>
          <p>
            El diseño mantiene la estructura institucional de nuestras páginas de datos: líneas, jerarquía tipográfica y módulos editoriales listos para convertirse en briefs, visualizaciones y notas metodológicas.
          </p>
        </div>

        <div class="institutional-panels">
          <section class="institutional-panel" aria-labelledby="historia-features">
            <p class="institutional-panel__number">01</p>
            <div>
              <p class="institutional-kicker institutional-kicker--green">Contenido</p>
              <h3 id="historia-features">Líneas de trabajo</h3>
              <ul>
                {features.map((feature) => <li>{feature}</li>)}
              </ul>
            </div>
          </section>

          <section class="institutional-panel" aria-labelledby="historia-next">
            <p class="institutional-panel__number institutional-panel__number--red">02</p>
            <div>
              <p class="institutional-kicker institutional-kicker--red">Desarrollo</p>
              <h3 id="historia-next">Siguientes pasos</h3>
              <ul>
                {nextSteps.map((step) => <li>{step}</li>)}
              </ul>
            </div>
          </section>
        </div>
      </div>

      <section id="publicaciones-historia" class="history-publications container" aria-labelledby="history-publications-title">
        <header class="history-publications__header">
          <div>
            <p class="institutional-kicker institutional-kicker--green">Próximas publicaciones</p>
            <h2 id="history-publications-title">Briefs visuales en preparación</h2>
            <p>
              Placeholders editoriales para las próximas visualizaciones sobre la historia económica de México.
            </p>
          </div>
          <div class="history-view-toggle" aria-label="Vista de publicaciones">
            <button type="button" aria-label="Vista en cuadrícula"><span></span><span></span><span></span><span></span></button>
            <button type="button" aria-label="Vista en lista"><span></span><span></span></button>
          </div>
        </header>

        <div class="history-publication-grid">
          {publications.map((publication) => (
            <article class={`history-publication-card history-publication-card--${publication.visual}`}>
              <div class="history-publication-card__copy">
                <p>{publication.period}</p>
                <h3>{publication.title}</h3>
                <span>{publication.status}</span>
              </div>
              <div class="history-publication-card__visual" aria-hidden="true">
                <i></i><i></i><i></i><i></i><i></i>
              </div>
              <p class="history-publication-card__description">{publication.description}</p>
            </article>
          ))}
        </div>
      </section>
    </section>
  </main>
</BaseLayout>

<style>
  .institutional-page {
    background: #fffdfa;
    color: var(--color-ink);
  }

  .institutional-hero {
    padding: clamp(2rem, 5vw, 4.75rem) 0 clamp(2rem, 5vw, 4.5rem);
  }

  .institutional-hero__grid {
    display: grid;
    gap: clamp(2rem, 5vw, 4.5rem);
    border-top: 2px solid var(--color-ink);
    padding-top: clamp(1rem, 2.5vw, 1.45rem);
  }

  .institutional-hero__copy {
    min-width: 0;
  }

  .institutional-kicker {
    display: inline-flex;
    width: fit-content;
    margin: 0;
    color: #f7f3ea;
    background: var(--color-primary);
    padding: 0.36rem 0.72rem;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    line-height: 1;
    text-transform: uppercase;
  }

  .institutional-kicker--green {
    background: transparent;
    color: var(--color-primary);
    padding: 0;
  }

  .institutional-kicker--red {
    background: transparent;
    color: var(--color-red-700, #c51d23);
    padding: 0;
  }

  .institutional-hero h1 {
    max-width: 980px;
    margin: 1rem 0 1.1rem;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(3.15rem, 7.4vw, 7.1rem);
    font-weight: 600;
    letter-spacing: -0.067em;
    line-height: 0.92;
    text-wrap: balance;
  }

  .institutional-dek {
    max-width: 780px;
    margin: 0;
    color: #3f454d;
    font-family: var(--font-serif);
    font-size: clamp(1.18rem, 2.1vw, 1.62rem);
    font-style: italic;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.36;
  }

  .institutional-status {
    border-top: 2px solid var(--color-ink);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 0 1.2rem;
  }

  .institutional-status__label {
    margin: 0;
    color: var(--color-red-700, #c51d23);
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    line-height: 1;
    text-transform: uppercase;
  }

  .institutional-status p:last-child {
    margin: 0.85rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.92rem;
    line-height: 1.62;
  }

  .institutional-actions {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .institutional-actions__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem 1.4rem;
    align-items: center;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }

  .institutional-action {
    display: inline-flex;
    min-height: 42px;
    align-items: center;
    gap: 0.65rem;
    border-bottom: 2px solid var(--color-ink);
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
    transition: color var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
  }

  .institutional-action--primary {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .institutional-action:hover,
  .institutional-action:focus-visible {
    color: var(--color-red-700, #c51d23);
    border-color: var(--color-red-700, #c51d23);
    transform: translateY(-2px);
  }

  .institutional-body {
    padding: clamp(2.5rem, 6vw, 5rem) 0 clamp(4rem, 8vw, 6.5rem);
  }

  .institutional-body__grid {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .institutional-body__intro {
    border-top: 2px solid var(--color-ink);
    border-bottom: 1px solid var(--color-border);
    padding: 1.1rem 0 1.25rem;
  }

  .institutional-body__intro h2,
  .history-publications__header h2 {
    margin: 0.65rem 0 0.85rem;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 3.8vw, 3.35rem);
    font-weight: 600;
    letter-spacing: -0.045em;
    line-height: 1.05;
  }

  .institutional-body__intro p:last-child,
  .history-publications__header p:last-child {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.96rem;
    line-height: 1.62;
  }

  .institutional-panels {
    display: grid;
    border-top: 2px solid var(--color-ink);
  }

  .institutional-panel {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr);
    gap: clamp(1rem, 3vw, 1.65rem);
    border-bottom: 1px solid var(--color-border);
    padding: clamp(1.25rem, 3vw, 1.75rem) 0;
  }

  .institutional-panel__number {
    margin: 0;
    color: var(--color-primary);
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 2.7rem);
    font-weight: 600;
    letter-spacing: -0.055em;
    line-height: 0.92;
  }

  .institutional-panel__number--red {
    color: var(--color-red-700, #c51d23);
  }

  .institutional-panel h3 {
    margin: 0.55rem 0 1rem;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 3vw, 2.1rem);
    font-weight: 600;
    letter-spacing: -0.036em;
    line-height: 1.08;
  }

  .institutional-panel ul {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .institutional-panel li {
    border-top: 1px solid var(--color-border);
    color: var(--color-text);
    font-size: clamp(0.98rem, 1.35vw, 1.08rem);
    line-height: 1.58;
    padding: 0.75rem 0;
  }

  .institutional-panel li:first-child {
    border-top-color: rgba(17, 17, 17, 0.22);
  }

  .history-publications {
    margin-top: clamp(3rem, 6vw, 5rem);
  }

  .history-publications__header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
    border-top: 2px solid var(--color-ink);
    border-bottom: 1px solid var(--color-border);
    padding: 1.15rem 0 1.25rem;
  }

  .history-publications__header > div:first-child {
    max-width: 760px;
  }

  .history-view-toggle {
    display: inline-flex;
    gap: 0.55rem;
  }

  .history-view-toggle button {
    width: 42px;
    height: 42px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4px;
    border: 1px solid var(--color-border);
    background: transparent;
    padding: 10px;
  }

  .history-view-toggle button:nth-child(2) {
    grid-template-columns: 1fr;
    grid-template-rows: repeat(2, 1fr);
  }

  .history-view-toggle span {
    border: 2px solid var(--color-ink);
  }

  .history-publication-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1rem, 2.2vw, 1.5rem);
    margin-top: clamp(1.4rem, 3vw, 2rem);
  }

  .history-publication-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(170px, 0.44fr);
    gap: 1rem;
    min-height: 270px;
    border: 1px solid var(--color-border);
    background: #fffdfa;
    overflow: hidden;
  }

  .history-publication-card__copy {
    padding: clamp(1rem, 2vw, 1.35rem) 0 0 clamp(1rem, 2vw, 1.35rem);
  }

  .history-publication-card__copy > p {
    margin: 0 0 0.7rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 850;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .history-publication-card h3 {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 2.4vw, 2.05rem);
    font-weight: 600;
    letter-spacing: -0.042em;
    line-height: 1.08;
  }

  .history-publication-card__copy span {
    display: inline-flex;
    border-top: 1px solid var(--color-border);
    margin-top: 1.15rem;
    padding-top: 0.65rem;
    color: var(--color-red-700, #c51d23);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 850;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .history-publication-card__visual {
    position: relative;
    min-height: 190px;
    background:
      radial-gradient(circle at 48% 42%, rgba(153, 207, 191, 0.18), transparent 8rem),
      linear-gradient(135deg, #0a1415, #17382e 54%, #111827);
    overflow: hidden;
  }

  .history-publication-card__visual i {
    position: absolute;
    display: block;
  }

  .history-publication-card--city .history-publication-card__visual i {
    bottom: 24%;
    width: 9%;
    border: 1px solid rgba(170, 227, 211, 0.4);
    background: rgba(77, 169, 150, 0.22);
  }

  .history-publication-card--city .history-publication-card__visual i:nth-child(1) { left: 18%; height: 26%; }
  .history-publication-card--city .history-publication-card__visual i:nth-child(2) { left: 32%; height: 44%; }
  .history-publication-card--city .history-publication-card__visual i:nth-child(3) { left: 47%; height: 34%; }
  .history-publication-card--city .history-publication-card__visual i:nth-child(4) { left: 61%; height: 52%; }
  .history-publication-card--city .history-publication-card__visual i:nth-child(5) { left: 75%; height: 30%; }

  .history-publication-card--ledger .history-publication-card__visual i {
    left: -12%;
    width: 132%;
    height: 2px;
    transform: rotate(-22deg);
    background: rgba(203, 220, 214, 0.24);
  }

  .history-publication-card--ledger .history-publication-card__visual i:nth-child(1) { top: 20%; }
  .history-publication-card--ledger .history-publication-card__visual i:nth-child(2) { top: 34%; }
  .history-publication-card--ledger .history-publication-card__visual i:nth-child(3) { top: 48%; }
  .history-publication-card--ledger .history-publication-card__visual i:nth-child(4) { top: 62%; }
  .history-publication-card--ledger .history-publication-card__visual i:nth-child(5) { top: 76%; }

  .history-publication-card--lines .history-publication-card__visual i {
    height: 2px;
    width: 58%;
    left: 22%;
    transform-origin: left center;
    background: rgba(178, 226, 211, 0.42);
  }

  .history-publication-card--lines .history-publication-card__visual i:nth-child(1) { top: 65%; transform: rotate(-18deg); }
  .history-publication-card--lines .history-publication-card__visual i:nth-child(2) { top: 56%; transform: rotate(10deg); }
  .history-publication-card--lines .history-publication-card__visual i:nth-child(3) { top: 45%; transform: rotate(-8deg); }
  .history-publication-card--lines .history-publication-card__visual i:nth-child(4) { top: 36%; transform: rotate(14deg); }
  .history-publication-card--lines .history-publication-card__visual i:nth-child(5) { top: 28%; transform: rotate(-12deg); background: rgba(201, 40, 45, 0.65); }

  .history-publication-card--bars .history-publication-card__visual i {
    bottom: 18%;
    width: 9%;
    background: rgba(213, 226, 221, 0.28);
  }

  .history-publication-card--bars .history-publication-card__visual i:nth-child(1) { left: 18%; height: 30%; }
  .history-publication-card--bars .history-publication-card__visual i:nth-child(2) { left: 33%; height: 62%; }
  .history-publication-card--bars .history-publication-card__visual i:nth-child(3) { left: 48%; height: 42%; background: rgba(201, 40, 45, 0.54); }
  .history-publication-card--bars .history-publication-card__visual i:nth-child(4) { left: 63%; height: 74%; }
  .history-publication-card--bars .history-publication-card__visual i:nth-child(5) { left: 78%; height: 48%; }

  .history-publication-card__description {
    grid-column: 1 / -1;
    align-self: end;
    border-top: 1px solid var(--color-border);
    margin: 0;
    padding: 1rem clamp(1rem, 2vw, 1.35rem);
    color: var(--color-text-muted);
    font-size: 0.92rem;
    line-height: 1.58;
  }

  @media (min-width: 960px) {
    .institutional-hero__grid {
      grid-template-columns: minmax(0, 1fr) minmax(260px, 370px);
      align-items: end;
    }

    .institutional-status {
      align-self: end;
    }

    .institutional-body__grid {
      grid-template-columns: minmax(230px, 320px) minmax(0, 1fr);
    }

    .institutional-body__intro {
      position: sticky;
      top: calc(var(--header-height) + 1.5rem);
    }
  }

  @media (max-width: 1040px) {
    .history-publication-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .history-publications__header {
      align-items: start;
      flex-direction: column;
    }

    .history-publication-card {
      grid-template-columns: 1fr;
    }

    .history-publication-card__copy {
      padding-right: 1.2rem;
    }
  }

  @media (max-width: 640px) {
    .institutional-panel {
      grid-template-columns: 1fr;
    }
  }
</style>
