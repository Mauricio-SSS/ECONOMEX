---
import BaseLayout from '../../layouts/BaseLayout.astro';

const featuredTimeline = [
  { year: '1521', label: 'Economía colonial' },
  { year: '1821', label: 'Independencia fiscal' },
  { year: '1877', label: 'Infraestructura y mercado' },
  { year: '1938', label: 'Estado desarrollista' },
  { year: '1982', label: 'Crisis de deuda' },
  { year: '1994', label: 'Apertura comercial' },
];

const briefs = [
  {
    eyebrow: 'Infraestructura 1920-1950',
    title: 'El Milagro Mexicano: visualizando el crecimiento industrial',
    description: 'Series históricas de producción, urbanización e inversión pública durante el periodo de industrialización acelerada.',
    status: 'Próximamente',
    kind: 'Visualización interactiva',
    visual: 'city',
  },
  {
    eyebrow: 'Finanzas públicas 1821-1910',
    title: 'Deuda, ingresos y construcción del Estado mexicano',
    description: 'Una lectura visual de las tensiones fiscales desde la independencia hasta el Porfiriato.',
    status: 'En diseño',
    kind: 'Brief histórico',
    visual: 'ledger',
  },
  {
    eyebrow: 'Comercio 1994-2026',
    title: 'Apertura comercial y transformación productiva',
    description: 'Cómo cambiaron exportaciones, manufactura regional y empleo formal después de la integración comercial.',
    status: 'Base de datos',
    kind: 'Serie comparativa',
    visual: 'lines',
  },
  {
    eyebrow: 'Moneda y precios 1900-2026',
    title: 'Inflación, crisis y estabilidad monetaria en México',
    description: 'Cronología visual de episodios inflacionarios, choques cambiarios y estabilización macroeconómica.',
    status: 'Próximamente',
    kind: 'Línea de tiempo',
    visual: 'bars',
  },
];

const archivePlaceholders = [
  'Series históricas normalizadas',
  'Notas metodológicas por fuente',
  'Visualizaciones interactivas',
  'Descargas CSV / XLSX',
];
---

<BaseLayout
  title="Historia económica de México — Centro Economex"
  description="Landing de datos históricos y visualizaciones sobre la historia de la economía mexicana."
>
  <main class="history-page">
    <section class="history-hero container" aria-labelledby="history-title">
      <div class="history-hero__copy">
        <p class="history-kicker">Edición especial · Historia</p>
        <h1 id="history-title">La historia de la economía mexicana</h1>
        <p>
          Un archivo editorial para explorar las fluctuaciones, transformaciones e hitos que definieron el panorama financiero de México desde la época colonial hasta la modernidad.
        </p>
        <div class="history-actions">
          <a href="#publicaciones">Explorar datos</a>
          <span>Lectura de 12 min</span>
        </div>
      </div>

      <figure class="history-hero__visual" aria-label="Placeholder de visualización histórica">
        <div class="archive-window" aria-hidden="true">
          <div class="archive-window__bar"><span></span><span></span><span></span></div>
          <div class="archive-bank">
            <i></i><i></i><i></i><i></i><i></i>
          </div>
          <div class="archive-slider"><span></span><b>1821</b><span></span></div>
        </div>
        <figcaption>
          <strong>Historia en datos</strong>
          <span>Esta sección será una biblioteca de briefs visuales, series históricas y notas metodológicas.</span>
        </figcaption>
      </figure>
    </section>

    <section class="history-timeline container" aria-labelledby="timeline-title">
      <div class="history-section-heading">
        <p class="history-kicker history-kicker--green">Panorama histórico</p>
        <h2 id="timeline-title">Ejes de lectura</h2>
      </div>
      <ol>
        {featuredTimeline.map((item) => (
          <li>
            <strong>{item.year}</strong>
            <span>{item.label}</span>
          </li>
        ))}
      </ol>
    </section>

    <section id="publicaciones" class="recent-history container" aria-labelledby="recent-title">
      <header>
        <div>
          <h2 id="recent-title">Publicaciones recientes</h2>
          <p>Visualizaciones interactivas y análisis de archivo.</p>
        </div>
        <div class="view-buttons" aria-label="Cambiar vista">
          <button type="button" aria-label="Vista en cuadrícula"><span></span><span></span><span></span><span></span></button>
          <button type="button" aria-label="Vista en lista"><span></span><span></span></button>
        </div>
      </header>

      <div class="brief-grid">
        {briefs.map((brief) => (
          <article class={`brief-card brief-card--${brief.visual}`}>
            <div class="brief-card__copy">
              <p>{brief.eyebrow}</p>
              <h3>{brief.title}</h3>
              <span>{brief.kind}</span>
              <small>{brief.status}</small>
            </div>
            <div class="brief-card__visual" aria-hidden="true">
              <i></i><i></i><i></i><i></i><i></i>
            </div>
            <p class="brief-card__description">{brief.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="history-archive container" aria-labelledby="archive-title">
      <div>
        <p class="history-kicker history-kicker--green">Próxima carga</p>
        <h2 id="archive-title">Repositorio para briefs y visualizaciones</h2>
        <p>
          Estos espacios funcionan como placeholders editoriales para las próximas piezas de historia económica. Cuando carguemos los briefs finales, cada módulo podrá convertirse en artículo, dashboard o ficha metodológica.
        </p>
      </div>
      <ul>
        {archivePlaceholders.map((item) => <li>{item}<span>→</span></li>)}
      </ul>
    </section>
  </main>
</BaseLayout>

<style>
  .history-page {
    --history-bg: #f7f7fb;
    --history-paper: #fffdfa;
    --history-ink: #111827;
    --history-muted: #4b5563;
    --history-line: #d6d8df;
    --history-green: var(--color-primary, #005c3a);
    --history-red: var(--color-red-700, #c9282d);
    background:
      linear-gradient(90deg, rgba(17, 24, 39, 0.025) 1px, transparent 1px),
      var(--history-bg);
    background-size: 48px 48px;
    color: var(--history-ink);
    padding: clamp(2rem, 4vw, 3.5rem) 0 clamp(4rem, 8vw, 7rem);
  }

  .history-kicker {
    margin: 0;
    color: var(--history-green);
    font-family: var(--font-sans);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .history-kicker--green {
    color: var(--history-green);
  }

  .history-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 1.04fr);
    border: 1px solid var(--history-line);
    background: var(--history-paper);
    min-height: clamp(470px, 54vw, 620px);
  }

  .history-hero__copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(2rem, 5vw, 4.1rem);
  }

  .history-hero h1 {
    max-width: 620px;
    margin: 0.6rem 0 1.25rem;
    color: var(--history-ink);
    font-family: var(--font-serif);
    font-size: clamp(3.1rem, 6.2vw, 6rem);
    font-weight: 600;
    letter-spacing: -0.066em;
    line-height: 0.95;
    text-wrap: balance;
  }

  .history-hero__copy > p:not(.history-kicker) {
    max-width: 560px;
    margin: 0;
    color: #2f3742;
    font-size: clamp(1.02rem, 1.6vw, 1.24rem);
    line-height: 1.75;
  }

  .history-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.1rem;
    margin-top: clamp(1.8rem, 4vw, 2.6rem);
  }

  .history-actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    background: var(--history-green);
    color: #f7f3ea;
    padding: 0.9rem 1.45rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .history-actions span {
    color: var(--history-muted);
    font-size: 0.95rem;
  }

  .history-hero__visual {
    position: relative;
    margin: 0;
    min-height: 100%;
    background:
      radial-gradient(circle at 60% 18%, rgba(255,255,255,0.18), transparent 16rem),
      linear-gradient(180deg, #070b0d, #0b1717 58%, #060909);
    overflow: hidden;
  }

  .archive-window {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-rows: 64px 1fr 82px;
    color: rgba(240, 247, 242, 0.82);
  }

  .archive-window__bar {
    display: flex;
    justify-content: flex-end;
    gap: 0.45rem;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    padding: 0 1.6rem;
    background: rgba(0,0,0,0.4);
  }

  .archive-window__bar span {
    width: 8px;
    height: 8px;
    border: 1px solid rgba(255,255,255,0.4);
    border-radius: 999px;
  }

  .archive-bank {
    position: relative;
    align-self: end;
    justify-self: center;
    width: min(78%, 560px);
    height: 70%;
    border: 1px solid rgba(196, 219, 205, 0.2);
    border-bottom: 0;
    background:
      linear-gradient(180deg, rgba(232, 243, 237, 0.09), rgba(232, 243, 237, 0.015)),
      repeating-linear-gradient(90deg, transparent 0 58px, rgba(255,255,255,0.07) 58px 59px);
    box-shadow: inset 0 -90px 90px rgba(0, 0, 0, 0.45);
  }

  .archive-bank::before {
    content: '';
    position: absolute;
    left: 50%;
    top: -54px;
    width: 46%;
    height: 72px;
    transform: translateX(-50%);
    clip-path: polygon(50% 0, 100% 78%, 0 78%);
    background: rgba(232, 243, 237, 0.13);
    border: 1px solid rgba(196, 219, 205, 0.18);
  }

  .archive-bank i {
    position: absolute;
    bottom: 12%;
    width: 13%;
    height: 47%;
    border: 1px solid rgba(196, 219, 205, 0.24);
    border-radius: 999px 999px 0 0;
    background: linear-gradient(180deg, rgba(255,255,255,0.1), rgba(0,0,0,0.12));
  }

  .archive-bank i:nth-child(1) { left: 9%; }
  .archive-bank i:nth-child(2) { left: 27%; }
  .archive-bank i:nth-child(3) { left: 45%; }
  .archive-bank i:nth-child(4) { left: 63%; }
  .archive-bank i:nth-child(5) { left: 81%; transform: translateX(-50%); }

  .archive-slider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    background: rgba(0,0,0,0.55);
  }

  .archive-slider span {
    width: 84px;
    height: 4px;
    background: rgba(255,255,255,0.18);
  }

  .archive-slider span:first-child::after {
    content: '';
    display: block;
    width: 11px;
    height: 11px;
    margin-top: -3px;
    margin-left: 58%;
    border-radius: 999px;
    background: #9ed6dc;
  }

  .archive-slider b {
    color: rgba(255,255,255,0.7);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
  }

  .history-hero__visual figcaption {
    position: absolute;
    left: clamp(1rem, 4vw, 2.6rem);
    bottom: clamp(1rem, 4vw, 2.4rem);
    width: min(68%, 380px);
    background: rgba(255, 253, 250, 0.96);
    border: 1px solid var(--history-line);
    padding: clamp(1rem, 2vw, 1.35rem);
  }

  .history-hero__visual figcaption strong,
  .history-hero__visual figcaption span {
    display: block;
  }

  .history-hero__visual figcaption strong {
    color: var(--history-green);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .history-hero__visual figcaption span {
    color: #27323a;
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .history-timeline,
  .recent-history,
  .history-archive {
    margin-top: clamp(2.8rem, 6vw, 4.5rem);
  }

  .history-section-heading h2,
  .recent-history h2,
  .history-archive h2 {
    margin: 0.45rem 0 0;
    color: var(--history-ink);
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4.2vw, 3.7rem);
    font-weight: 600;
    letter-spacing: -0.05em;
    line-height: 1.02;
  }

  .history-timeline ol {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    border-top: 2px solid var(--history-ink);
    border-bottom: 1px solid var(--history-line);
    margin: 1.2rem 0 0;
    padding: 0;
    list-style: none;
  }

  .history-timeline li {
    display: grid;
    gap: 0.35rem;
    min-height: 116px;
    border-right: 1px solid var(--history-line);
    padding: 1rem 0.9rem;
  }

  .history-timeline li:last-child {
    border-right: 0;
  }

  .history-timeline strong {
    color: var(--history-red);
    font-family: var(--font-serif);
    font-size: 1.55rem;
    font-weight: 600;
    letter-spacing: -0.05em;
  }

  .history-timeline span {
    color: var(--history-muted);
    font-size: 0.84rem;
    line-height: 1.35;
  }

  .recent-history header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    border-bottom: 2px solid var(--history-line);
    padding-bottom: 1rem;
  }

  .recent-history header p {
    margin: 0.35rem 0 0;
    color: var(--history-muted);
  }

  .view-buttons {
    display: inline-flex;
    gap: 0.55rem;
  }

  .view-buttons button {
    width: 42px;
    height: 42px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4px;
    border: 1px solid var(--history-line);
    background: transparent;
    padding: 10px;
  }

  .view-buttons button:nth-child(2) {
    grid-template-columns: 1fr;
    grid-template-rows: repeat(2, 1fr);
  }

  .view-buttons span {
    border: 2px solid var(--history-ink);
  }

  .brief-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1rem, 2.5vw, 1.6rem);
    margin-top: clamp(1.4rem, 3vw, 2rem);
  }

  .brief-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(180px, 0.48fr);
    gap: 1rem;
    border: 1px solid var(--history-line);
    background: var(--history-paper);
    min-height: 280px;
    overflow: hidden;
  }

  .brief-card__copy {
    padding: clamp(1rem, 2vw, 1.4rem) 0 0 clamp(1rem, 2vw, 1.4rem);
  }

  .brief-card__copy > p {
    margin: 0 0 0.65rem;
    color: var(--history-muted);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .brief-card h3 {
    margin: 0;
    color: var(--history-ink);
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 2.5vw, 2.1rem);
    font-weight: 600;
    letter-spacing: -0.045em;
    line-height: 1.08;
  }

  .brief-card__copy span,
  .brief-card__copy small {
    display: block;
    margin-top: 1rem;
    color: var(--history-green);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .brief-card__copy small {
    color: var(--history-red);
    margin-top: 0.35rem;
  }

  .brief-card__visual {
    position: relative;
    min-height: 210px;
    background:
      radial-gradient(circle at 48% 42%, rgba(139, 213, 211, 0.18), transparent 7rem),
      linear-gradient(135deg, #0a1415, #16372e 54%, #111827);
    overflow: hidden;
  }

  .brief-card__visual i {
    position: absolute;
    display: block;
    background: rgba(149, 211, 194, 0.5);
  }

  .brief-card--city .brief-card__visual i {
    bottom: 24%;
    width: 9%;
    border: 1px solid rgba(170, 227, 211, 0.4);
    background: rgba(77, 169, 150, 0.2);
  }

  .brief-card--city .brief-card__visual i:nth-child(1) { left: 18%; height: 26%; }
  .brief-card--city .brief-card__visual i:nth-child(2) { left: 32%; height: 44%; }
  .brief-card--city .brief-card__visual i:nth-child(3) { left: 47%; height: 34%; }
  .brief-card--city .brief-card__visual i:nth-child(4) { left: 61%; height: 52%; }
  .brief-card--city .brief-card__visual i:nth-child(5) { left: 75%; height: 30%; }

  .brief-card--ledger .brief-card__visual i {
    left: -12%;
    width: 132%;
    height: 2px;
    transform: rotate(-22deg);
    background: rgba(203, 220, 214, 0.22);
  }

  .brief-card--ledger .brief-card__visual i:nth-child(1) { top: 20%; }
  .brief-card--ledger .brief-card__visual i:nth-child(2) { top: 34%; }
  .brief-card--ledger .brief-card__visual i:nth-child(3) { top: 48%; }
  .brief-card--ledger .brief-card__visual i:nth-child(4) { top: 62%; }
  .brief-card--ledger .brief-card__visual i:nth-child(5) { top: 76%; }

  .brief-card--lines .brief-card__visual i {
    height: 2px;
    width: 58%;
    left: 22%;
    transform-origin: left center;
    background: rgba(178, 226, 211, 0.42);
  }

  .brief-card--lines .brief-card__visual i:nth-child(1) { top: 65%; transform: rotate(-18deg); }
  .brief-card--lines .brief-card__visual i:nth-child(2) { top: 56%; transform: rotate(10deg); }
  .brief-card--lines .brief-card__visual i:nth-child(3) { top: 45%; transform: rotate(-8deg); }
  .brief-card--lines .brief-card__visual i:nth-child(4) { top: 36%; transform: rotate(14deg); }
  .brief-card--lines .brief-card__visual i:nth-child(5) { top: 28%; transform: rotate(-12deg); background: rgba(201, 40, 45, 0.65); }

  .brief-card--bars .brief-card__visual i {
    bottom: 18%;
    width: 9%;
    background: rgba(213, 226, 221, 0.25);
  }

  .brief-card--bars .brief-card__visual i:nth-child(1) { left: 18%; height: 30%; }
  .brief-card--bars .brief-card__visual i:nth-child(2) { left: 33%; height: 62%; }
  .brief-card--bars .brief-card__visual i:nth-child(3) { left: 48%; height: 42%; background: rgba(201, 40, 45, 0.54); }
  .brief-card--bars .brief-card__visual i:nth-child(4) { left: 63%; height: 74%; }
  .brief-card--bars .brief-card__visual i:nth-child(5) { left: 78%; height: 48%; }

  .brief-card__description {
    grid-column: 1 / -1;
    align-self: end;
    border-top: 1px solid var(--history-line);
    margin: 0;
    padding: 1rem clamp(1rem, 2vw, 1.4rem);
    color: var(--history-muted);
    font-size: 0.94rem;
    line-height: 1.58;
  }

  .history-archive {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.8fr);
    gap: clamp(2rem, 5vw, 4rem);
    border-top: 2px solid var(--history-ink);
    border-bottom: 1px solid var(--history-line);
    padding-top: clamp(1.2rem, 3vw, 1.8rem);
    padding-bottom: clamp(1.2rem, 3vw, 1.8rem);
  }

  .history-archive p:not(.history-kicker) {
    max-width: 640px;
    color: var(--history-muted);
    line-height: 1.7;
  }

  .history-archive ul {
    margin: 0;
    padding: 0;
    list-style: none;
    border-bottom: 1px solid var(--history-line);
  }

  .history-archive li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid var(--history-line);
    padding: 1rem 0;
    color: var(--history-ink);
    font-weight: 760;
  }

  .history-archive li span {
    color: var(--history-red);
  }

  @media (max-width: 1040px) {
    .history-hero,
    .brief-grid,
    .history-archive {
      grid-template-columns: 1fr;
    }

    .history-hero__visual {
      min-height: 460px;
    }

    .history-timeline ol {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .history-page {
      padding-top: 1rem;
    }

    .history-hero {
      border-left: 0;
      border-right: 0;
    }

    .history-hero__copy {
      padding: 1.4rem;
    }

    .history-hero h1 {
      font-size: clamp(2.7rem, 14vw, 4.4rem);
    }

    .history-hero__visual {
      min-height: 390px;
    }

    .history-hero__visual figcaption {
      position: relative;
      left: auto;
      bottom: auto;
      width: 100%;
      border-left: 0;
      border-right: 0;
    }

    .archive-window {
      position: relative;
      min-height: 320px;
    }

    .history-timeline ol {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .recent-history header {
      align-items: start;
      flex-direction: column;
    }

    .brief-card {
      grid-template-columns: 1fr;
    }

    .brief-card__copy {
      padding-right: 1.2rem;
    }
  }
</style>
