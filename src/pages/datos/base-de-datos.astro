      { tag: 'INEGI', title: 'Indice Nacional de Precios al Consumidor', description: 'Inflacion general, subyacente, no subyacente, objeto de gasto, ciudad y componentes.', format: 'API / CSV', href: 'https://www.inegi.org.mx/temas/inpc/' },
