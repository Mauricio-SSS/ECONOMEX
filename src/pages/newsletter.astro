---
import SectionPlaceholder from '../components/placeholder/SectionPlaceholder.astro';
const email = Astro.url.searchParams.get('email') ?? '';
---

<SectionPlaceholder
  title="Newsletter"
  description="Recibe análisis económico, datos explicados y publicaciones recientes de Centro Economex en tu correo."
  eyebrow="Boletín"
  status="Formulario temporal"
  features={['Resumen semanal', 'Datos explicados', 'Nuevas publicaciones']}
  nextSteps={['Conectar proveedor de newsletter.', 'Agregar confirmación por correo.', 'Crear archivo del boletín.']}
>
  <form class="inline-form" action="/newsletter" method="get">
    <label for="newsletter-email" class="visually-hidden">Correo electrónico</label>
    <input id="newsletter-email" name="email" type="email" value={email} placeholder="tu@correo.com" autocomplete="email" />
    <button type="submit">Suscribirme</button>
    {email && <p class="form-note">Gracias. El alta automática del newsletter se conectará en la siguiente fase.</p>}
  </form>
</SectionPlaceholder>
