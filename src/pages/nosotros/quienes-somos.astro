---
import BaseLayout from '../../layouts/BaseLayout.astro';

const heroImage = 'https://source.unsplash.com/CFB20Nc9t3A/1600x1100';
const valueImage = 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=1400&q=82';

const values = [
  {
    number: '01',
    title: 'Investigación rigurosa',
    description:
      'Aplicamos métodos cuantitativos de vanguardia y estándares internacionales para generar conocimiento relevante, replicable y con impacto en realidades mexicanas.',
    image: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=1000&q=82',
  },
  {
    number: '02',
    title: 'Independencia',
    description:
      'Mantenemos una autonomía intelectual completa. Nuestro financiamiento es diversificado para asegurar que el análisis nunca se vea comprometido.',
    image: '/images/mission/0f79e800-e3f3-4fae-a35c-eda961fe7cdb.png',
  },
  {
    number: '03',
    title: 'Impacto social',
    description:
      'Buscamos que nuestra investigación se traduzca en mejores decisiones y en políticas públicas efectivas que eleven la calidad de vida de los ciudadanos.',
    image: 'https://source.unsplash.com/gFRe3IYSfRo/1000x650',
  },
];

const leaders = [
  {
    name: 'Dr. Adrián Salgado',
    role: 'Director ejecutivo',
    bio: 'PhD en Economía por la Universidad de Chicago. Especialista en políticas de competencia y regulación con más de 20 años de experiencia en organismos internacionales.',
    image: 'https://images.unsplash.com/photo-1560250097-0b93528c311a?auto=format&fit=crop&w=650&q=82',
  },
  {
    name: 'Mtra. Elena Vargas',
    role: 'Directora de investigación',
    bio: 'Investigadora sénior especializada en economía conductual y análisis de mercados laborales. Ex comisionada de políticas públicas sectoriales.',
    image: 'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&w=650&q=82',
  },
];
---

<BaseLayout
  title="¿Quiénes somos? — Centro Economex"
  description="Traducimos, distribuimos e impulsamos investigación económica en búsqueda del bien común."
>
  <main class="about-page">
    <section class="about-hero">
      <div class="about-hero__content">
        <div class="about-brand-mark" aria-hidden="true"></div>
        <p class="about-breadcrumb">Inicio / ¿Quiénes somos?</p>
        <h1>¿Quiénes somos?</h1>
        <i></i>
        <p class="about-hero__dek">Traducimos, distribuimos e impulsamos investigación económica en búsqueda del bien común.</p>
        <nav class="about-hero__links" aria-label="Acciones de página">
          <a href="/articulos">Ver catálogo <span>→</span></a>
          <a href="/">Volver al inicio <span>→</span></a>
        </nav>
      </div>

      <figure class="about-hero__image">
        <img src={heroImage} alt="Ángel de la Independencia y skyline económico de la Ciudad de México" loading="eager" decoding="async" />
        <figcaption>
          <strong>Investigación para México</strong>
          <span>Más conocimiento, mejores instituciones, mayor bienestar para las personas.</span>
        </figcaption>
      </figure>
    </section>

    <section class="value-proposition" aria-labelledby="value-title">
      <div class="value-proposition__copy">
        <p class="section-kicker">Nuestra</p>
        <h2 id="value-title">Propuesta de Valor</h2>
        <i></i>
        <p>
          En un mundo complejo y dinámico, la claridad no es un lujo: es una condición para el progreso económico y la toma de decisiones informadas.
        </p>
        <p>
          Centro Economex es un laboratorio de ideas independiente dedicado al análisis de la coyuntura económica mexicana e internacional. Nuestro objetivo es elevar el nivel de la discusión pública a través de datos verificables, metodologías robustas y pensamiento crítico.
        </p>
        <p>
          Creamos conocimiento público de alta calidad que contribuya al diseño de mejores políticas, al fortalecimiento de las instituciones y al desarrollo sostenible de México.
        </p>
      </div>
      <figure class="value-proposition__image">
        <img src={valueImage} alt="Visualización abstracta de datos económicos" loading="lazy" decoding="async" />
      </figure>
    </section>

    <section class="values-section" aria-labelledby="values-title">
      <p class="section-kicker">Valores fundamentales</p>
      <h2 id="values-title">Los pilares de nuestra excelencia académica</h2>
      <div class="values-grid">
        {values.map((value) => (
          <article class="value-card">
            <figure><img src={value.image} alt="" loading="lazy" decoding="async" /></figure>
            <div>
              <span>{value.number}</span>
              <h3>{value.title}</h3>
              <p>{value.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="leadership-section" aria-labelledby="leadership-title">
      <header>
        <p class="section-kicker">Liderazgo</p>
        <h2 id="leadership-title">Ejecutivo</h2>
        <a href="/nosotros/junta-directiva">Junta directiva <span>→</span></a>
      </header>
      <div class="leadership-grid">
        {leaders.map((leader) => (
          <article class="leader-card">
            <img src={leader.image} alt={`Retrato de ${leader.name}`} loading="lazy" decoding="async" />
            <div>
              <h3>{leader.name}</h3>
              <p class="leader-role">{leader.role}</p>
              <b></b>
              <p>{leader.bio}</p>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .about-page {
    --about-bg: #fffdfa;
    --about-ink: #0f2220;
    --about-muted: #4d5656;
    --about-line: #d9d5cb;
    --about-red: var(--color-red-700, #c9282d);
    --about-green: var(--color-primary, #005c3a);
    background:
      radial-gradient(circle at 18% 10%, rgba(0, 92, 58, 0.035), transparent 25rem),
      var(--about-bg);
    color: var(--about-ink);
  }

  .about-hero,
  .value-proposition,
  .values-section,
  .leadership-section {
    width: min(100%, 1240px);
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 3.5vw, 3.6rem);
  }

  .about-hero {
    min-height: clamp(620px, calc(100vh - var(--header-height)), 820px);
    display: grid;
    grid-template-columns: minmax(0, 0.94fr) minmax(380px, 1.06fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: center;
    border-bottom: 1px solid var(--about-line);
    padding-top: clamp(2rem, 5vw, 4.5rem);
    padding-bottom: clamp(2.5rem, 6vw, 4.5rem);
  }

  .about-brand-mark {
    width: 124px;
    aspect-ratio: 1;
    background: var(--about-green);
    margin-bottom: clamp(1.8rem, 4vw, 3.6rem);
  }

  .about-breadcrumb,
  .section-kicker,
  .leader-role {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .about-breadcrumb {
    color: var(--about-muted);
    margin-bottom: 1.35rem;
  }

  .section-kicker,
  .leader-role {
    color: var(--about-red);
  }

  .about-hero h1 {
    max-width: 620px;
    margin: 0;
    color: var(--about-green);
    font-family: var(--font-serif);
    font-size: clamp(4.2rem, 9.4vw, 8.6rem);
    font-weight: 600;
    letter-spacing: -0.075em;
    line-height: 0.9;
    text-wrap: balance;
  }

  .about-hero__content > i,
  .value-proposition__copy > i {
    display: block;
    width: 82px;
    height: 3px;
    background: var(--about-red);
    margin: clamp(1.4rem, 2.7vw, 2rem) 0;
  }

  .about-hero__dek {
    max-width: 520px;
    margin: 0;
    color: #223331;
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2.25vw, 1.85rem);
    font-style: italic;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.42;
  }

  .about-hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.8rem, 4vw, 3rem);
    margin-top: clamp(2rem, 4vw, 3.2rem);
  }

  .about-hero__links a,
  .leadership-section header a {
    display: inline-flex;
    gap: 0.75rem;
    align-items: center;
    border-bottom: 1px solid var(--about-green);
    padding-bottom: 0.45rem;
    color: var(--about-green);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: color var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
  }

  .about-hero__links a span,
  .leadership-section header a span {
    color: var(--about-red);
    font-size: 1rem;
  }

  .about-hero__links a:hover,
  .leadership-section header a:hover {
    color: var(--about-red);
    border-color: var(--about-red);
    transform: translateY(-2px);
  }

  .about-hero__image {
    position: relative;
    margin: 0;
    align-self: start;
    justify-self: end;
    width: min(100%, 600px);
  }

  .about-hero__image img {
    width: 100%;
    aspect-ratio: 1.18;
    object-fit: cover;
    filter: saturate(0.78) contrast(1.08);
  }

  .about-hero__image::after,
  .value-proposition__image::after,
  .value-card figure::after,
  .leader-card > img::after {
    content: '';
  }

  .about-hero__image figcaption {
    position: absolute;
    right: 0;
    bottom: 0;
    width: min(68%, 390px);
    background: rgba(255, 253, 250, 0.96);
    border: 1px solid var(--about-line);
    border-left: 0;
    padding: clamp(1rem, 2vw, 1.4rem);
    color: var(--about-ink);
    transform: translateY(18%);
  }

  .about-hero__image figcaption strong,
  .about-hero__image figcaption span {
    display: block;
  }

  .about-hero__image figcaption strong {
    color: var(--about-green);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .about-hero__image figcaption span {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.3vw, 1.18rem);
    line-height: 1.35;
  }

  .value-proposition {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(380px, 1fr);
    min-height: 520px;
    border-bottom: 1px solid var(--about-line);
    padding-top: 0;
    padding-bottom: 0;
  }

  .value-proposition__copy {
    align-self: center;
    padding: clamp(3rem, 7vw, 5.6rem) clamp(2rem, 4vw, 4rem) clamp(3rem, 7vw, 5.6rem) 0;
  }

  .value-proposition h2,
  .values-section h2,
  .leadership-section h2 {
    margin: 0;
    color: var(--about-green);
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 5.2vw, 4.6rem);
    font-weight: 600;
    letter-spacing: -0.055em;
    line-height: 1;
  }

  .value-proposition__copy p:not(.section-kicker) {
    margin: 0 0 1.25rem;
    color: #243230;
    font-size: clamp(0.98rem, 1.1vw, 1.05rem);
    line-height: 1.8;
  }

  .value-proposition__image {
    margin: 0 calc(clamp(1.25rem, 3.5vw, 3.6rem) * -1) 0 0;
    min-height: 100%;
  }

  .value-proposition__image img {
    width: 100%;
    height: 100%;
    min-height: 520px;
    object-fit: cover;
    filter: saturate(0.78) hue-rotate(38deg) contrast(1.02) brightness(0.82);
  }

  .values-section {
    border-bottom: 1px solid var(--about-line);
    padding-top: clamp(2.8rem, 6vw, 4.8rem);
    padding-bottom: clamp(3rem, 7vw, 5.2rem);
  }

  .values-section > h2 {
    max-width: 820px;
    margin-top: 0.45rem;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1.2rem, 2.4vw, 2rem);
    margin-top: clamp(1.5rem, 3.5vw, 2.4rem);
  }

  .value-card {
    border: 1px solid var(--about-line);
    background: rgba(255, 253, 250, 0.72);
  }

  .value-card figure {
    margin: 0;
    overflow: hidden;
  }

  .value-card img {
    width: 100%;
    aspect-ratio: 1.76;
    object-fit: cover;
    filter: saturate(0.76) contrast(1.05);
    transition: transform 500ms ease, filter 500ms ease;
  }

  .value-card:hover img {
    transform: scale(1.035);
    filter: saturate(0.95) contrast(1.08);
  }

  .value-card > div {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 1rem;
    row-gap: 0.6rem;
    padding: clamp(1rem, 2.4vw, 1.55rem);
  }

  .value-card span {
    grid-row: 1 / span 2;
    color: var(--about-red);
    font-family: var(--font-serif);
    font-size: 1.45rem;
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .value-card h3 {
    margin: 0;
    color: var(--about-ink);
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2vw, 1.65rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.05;
  }

  .value-card p {
    grid-column: 2;
    margin: 0;
    color: var(--about-muted);
    font-size: 0.95rem;
    line-height: 1.62;
  }

  .leadership-section {
    padding-top: clamp(2.8rem, 6vw, 4.4rem);
    padding-bottom: clamp(3.5rem, 8vw, 6rem);
  }

  .leadership-section header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: end;
    border-bottom: 2px solid var(--about-green);
    padding-bottom: 0.65rem;
  }

  .leadership-section header .section-kicker {
    grid-column: 1;
    align-self: center;
  }

  .leadership-section header h2 {
    grid-column: 1;
    color: var(--about-ink);
    font-size: clamp(2rem, 4vw, 3.2rem);
  }

  .leadership-section header a {
    grid-column: 3;
    grid-row: 1 / span 2;
    justify-self: end;
    border-bottom-color: transparent;
  }

  .leadership-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(2rem, 4vw, 4rem);
    margin-top: clamp(1.6rem, 4vw, 2.4rem);
  }

  .leader-card {
    display: grid;
    grid-template-columns: 210px 1fr;
    gap: clamp(1.4rem, 3vw, 2rem);
    align-items: start;
  }

  .leader-card > img {
    width: 100%;
    aspect-ratio: 0.82;
    object-fit: cover;
    filter: grayscale(1) contrast(1.06);
  }

  .leader-card h3 {
    margin: 0;
    color: var(--about-green);
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 2.2vw, 1.9rem);
    font-weight: 600;
    letter-spacing: -0.035em;
  }

  .leader-role {
    color: var(--about-green);
    margin-top: 0.45rem;
  }

  .leader-card b {
    display: block;
    width: 42px;
    height: 2px;
    background: var(--about-red);
    margin: 0.85rem 0 1rem;
  }

  .leader-card p:not(.leader-role) {
    margin: 0;
    color: var(--about-muted);
    font-size: 0.95rem;
    line-height: 1.72;
  }

  @media (max-width: 980px) {
    .about-hero,
    .value-proposition,
    .values-grid,
    .leadership-grid {
      grid-template-columns: 1fr;
    }

    .about-hero {
      min-height: auto;
    }

    .about-brand-mark {
      width: 90px;
      margin-bottom: 2rem;
    }

    .about-hero__image {
      width: 100%;
      justify-self: stretch;
    }

    .value-proposition__copy {
      padding-right: 0;
    }

    .value-proposition__image {
      margin: 0 calc(clamp(1.25rem, 3.5vw, 3.6rem) * -1);
    }

    .value-proposition__image img {
      min-height: 360px;
    }
  }

  @media (max-width: 680px) {
    .about-hero,
    .value-proposition,
    .values-section,
    .leadership-section {
      padding-inline: 1.1rem;
    }

    .about-hero h1 {
      font-size: clamp(3.3rem, 17vw, 5rem);
    }

    .about-hero__image figcaption {
      position: relative;
      width: 100%;
      transform: none;
      border-left: 1px solid var(--about-line);
    }

    .value-proposition__image {
      margin-inline: -1.1rem;
    }

    .value-card > div,
    .leader-card {
      grid-template-columns: 1fr;
    }

    .value-card p {
      grid-column: 1;
    }

    .leadership-section header {
      grid-template-columns: 1fr;
    }

    .leadership-section header h2,
    .leadership-section header a {
      grid-column: 1;
      grid-row: auto;
      justify-self: start;
    }

    .leader-card > img {
      max-width: 260px;
    }
  }
</style>
