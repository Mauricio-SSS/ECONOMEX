---
import SectionPlaceholder from '../components/placeholder/SectionPlaceholder.astro';
const query = Astro.url.searchParams.get('q') ?? '';
---

<SectionPlaceholder
  title="Buscar"
  description="Encuentra artículos, datos, temas y recursos publicados por Centro Economex."
  eyebrow="Búsqueda"
  status="Búsqueda en desarrollo"
  features={['Buscador por palabra clave', 'Filtros por tema y tipo de publicación', 'Resultados rápidos']}
  nextSteps={['Conectar índice de búsqueda local.', 'Agregar resultados destacados.', 'Incluir filtros por autor, tema y tipo de publicación.']}
>
  <form class="inline-form" action="/buscar" method="get" role="search">
    <label for="search-q" class="visually-hidden">Buscar</label>
    <input id="search-q" name="q" type="search" value={query} placeholder="Buscar artículos, datos o temas" />
    <button type="submit">Buscar</button>
    {query && <p class="form-note">La búsqueda avanzada se conectará pronto. Consulta mientras tanto la sección de artículos.</p>}
  </form>
</SectionPlaceholder>
