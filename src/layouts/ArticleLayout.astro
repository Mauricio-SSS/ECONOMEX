---
import BaseLayout from './BaseLayout.astro';

const { article } = Astro.props;
const date = new Intl.DateTimeFormat('es-MX', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(article.date);

const templateLabel = article.template?.replaceAll('-', ' ') ?? 'artículo';
const visualType = article.mainVisual?.type;
const hasMainVisual = Boolean(visualType && visualType !== 'none');
const hasSummaryPoints = (article.summaryPoints?.length ?? 0) > 0;
const hasSources = (article.sources?.length ?? 0) > 0;
---

<BaseLayout title={`${article.title} — Centro Economex`} description={article.abstract} ogImage={article.heroImage}>
  <article class="article-page">
    <header class="article-hero">
      <div class="container article-hero__inner">
        <p class="eyebrow">{templateLabel}</p>
        <h1>{article.title}</h1>
        <p class="one-sentence">{article.oneSentence}</p>

        <div class="article-meta" aria-label="Información del artículo">
          <span>{article.author}</span>
          <span aria-hidden="true">•</span>
          <time datetime={article.date.toISOString()}>{date}</time>
        </div>

        {article.heroImage && (
          <img class="hero-image" src={article.heroImage} alt="" loading="eager" decoding="async" />
        )}
      </div>
    </header>

    <div class="container article-shell">
      <aside class="article-aside" aria-label="Resumen">
        <div class="summary-card">
          <h2>Resumen</h2>
          <p>{article.abstract}</p>
        </div>

        {hasSummaryPoints && (
          <div class="summary-card">
            <h2>La idea en puntos</h2>
            <ol>
              {article.summaryPoints.map((point) => <li>{point}</li>)}
            </ol>
          </div>
        )}
      </aside>

      <div class="article-content">
        {hasMainVisual && (
          <figure class="visual-placeholder">
            <p class="eyebrow">Elemento visual principal</p>
            <h2>{article.mainVisual?.title ?? 'Visualización del artículo'}</h2>
            <p>
              Tipo: <strong>{visualType}</strong>
              {article.mainVisual?.dataset && <> · Dataset: <code>{article.mainVisual.dataset}</code></>}
            </p>
          </figure>
        )}

        <slot />

        {hasSources && (
          <section class="sources" aria-labelledby="sources-heading">
            <h2 id="sources-heading">Fuentes</h2>
            <ul>
              {article.sources.map((source) => (
                <li><a href={source.url} target="_blank" rel="noopener noreferrer">{source.label}</a></li>
              ))}
            </ul>
          </section>
        )}
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .article-page {
    background: linear-gradient(180deg, var(--color-bg-warm) 0, #fff 480px);
  }

  .article-hero {
    border-bottom: 1px solid var(--color-border);
  }

  .article-hero__inner {
    padding-top: var(--space-8);
    padding-bottom: var(--space-7);
  }

  .article-hero h1 {
    max-width: 860px;
    margin-top: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .one-sentence {
    max-width: 760px;
    color: var(--color-text);
    font-size: clamp(1.125rem, 2vw, 1.45rem);
    line-height: 1.45;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    color: var(--color-text-muted);
    font-size: var(--fs-sm);
    font-weight: 500;
    margin-top: var(--space-5);
  }

  .hero-image {
    width: 100%;
    max-height: 460px;
    object-fit: cover;
    border-radius: var(--radius-xl);
    margin-top: var(--space-6);
    border: 1px solid var(--color-border);
    background: #fff;
  }

  .article-shell {
    display: grid;
    gap: var(--space-7);
    padding-top: var(--space-8);
    padding-bottom: var(--space-12);
  }

  .article-aside {
    display: grid;
    gap: var(--space-4);
  }

  .summary-card,
  .visual-placeholder,
  .sources {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
  }

  .summary-card {
    padding: var(--space-5);
  }

  .summary-card h2,
  .sources h2,
  .visual-placeholder h2 {
    font-family: var(--font-sans);
    font-size: var(--fs-md);
    margin-bottom: var(--space-3);
  }

  .summary-card p,
  .summary-card li {
    font-size: var(--fs-sm);
    color: var(--color-text);
  }

  .summary-card ol {
    padding-left: 1.25rem;
    margin: 0;
  }

  .article-content {
    max-width: 760px;
    min-width: 0;
  }

  .article-content :global(p),
  .article-content :global(li) {
    font-size: clamp(1.05rem, 1.5vw, 1.18rem);
    line-height: 1.75;
  }

  .article-content :global(h2) {
    margin-top: var(--space-8);
  }

  .article-content :global(a) {
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .visual-placeholder {
    padding: var(--space-5);
    margin-bottom: var(--space-7);
    background: linear-gradient(135deg, #fff, var(--color-green-100));
  }

  .visual-placeholder code {
    font-size: var(--fs-sm);
    background: rgba(255,255,255,0.75);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.1rem 0.35rem;
  }

  .sources {
    margin-top: var(--space-8);
    padding: var(--space-5);
  }

  .sources ul {
    margin: 0;
    padding-left: 1.25rem;
  }

  @media (min-width: 960px) {
    .article-shell {
      grid-template-columns: minmax(220px, 280px) minmax(0, 760px);
      align-items: start;
    }

    .article-aside {
      position: sticky;
      top: calc(var(--header-height) + var(--space-5));
    }
  }
</style>
