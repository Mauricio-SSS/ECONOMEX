---
import BaseLayout from './BaseLayout.astro';

const { article } = Astro.props;
const date = new Intl.DateTimeFormat('es-MX', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(article.date);

const templateLabel = article.template?.replaceAll('-', ' ') ?? 'artículo';
const hasSummaryPoints = (article.summaryPoints?.length ?? 0) > 0;
const hasSources = (article.sources?.length ?? 0) > 0;
const readTime = article.readTime ?? '12 min de lectura';
const visualSummary = article.visualSummary ?? {};
const narrativeVisual = article.narrativeVisual ?? {};
const showVisualStorytelling = article.showVisualStorytelling ?? true;
const authorImage = article.authorImage ?? '/images/authors/default-profile.svg';
const visualTitle = visualSummary.title ?? article.mainVisual?.title ?? 'Brechas de crecimiento estatal';
const visualCaption = visualSummary.caption ?? 'Índice sintético de productividad, inversión y educación.';
const visualLowLabel = visualSummary.lowLabel ?? 'Bajo';
const visualHighLabel = visualSummary.highLabel ?? 'Alto';
const visualStats = [
  { value: visualSummary.statOneValue ?? '32', label: visualSummary.statOneLabel ?? 'entidades' },
  { value: visualSummary.statTwoValue ?? '2.4x', label: visualSummary.statTwoLabel ?? 'brecha PIB pc' },
  { value: visualSummary.statThreeValue ?? '18', label: visualSummary.statThreeLabel ?? 'indicadores' },
];
const narrativeSteps = narrativeVisual.steps?.length
  ? narrativeVisual.steps
  : ['Mapa estatal por productividad', 'Trayectoria de inversión pública', 'Educación técnica y salarios', 'Clusters regionales de crecimiento'];
---

<BaseLayout title={`${article.title} — Centro Economex`} description={article.abstract} ogImage={article.heroImage}>
  <article class="article-page">
    <div class={`article-grid container ${showVisualStorytelling ? '' : 'article-grid--no-visual'}`}>
      <main class="article-main">
        <header class="article-hero">
          <p class="article-eyebrow">{templateLabel}</p>
          <h1>{article.title}</h1>
          <p class="one-sentence">{article.oneSentence}</p>

          <div class="article-meta-panel" aria-label="Información del artículo">
            <div class="article-institution">
              <img
                class="article-author-image"
                src={authorImage}
                alt=""
                aria-hidden="true"
                loading="eager"
                decoding="async"
              />
              <div>
                <strong>{article.author ?? 'Centro Economex'}</strong>
                <span>Publicado el {date} • {readTime}</span>
              </div>
            </div>

            <div class="article-actions" aria-label="Acciones del artículo">
              <button type="button" aria-label="Compartir artículo">
                <svg viewBox="0 0 24 24" fill="none"><path d="M8.5 12.5 15.5 8.5M8.5 14.5l7 4M7 16a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm10-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm0 10a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" /></svg>
              </button>
              <button type="button" aria-label="Guardar artículo">
                <svg viewBox="0 0 24 24" fill="none"><path d="M7 4.5h10v15l-5-3-5 3v-15Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" /></svg>
              </button>
              <button type="button" aria-label="Imprimir artículo">
                <svg viewBox="0 0 24 24" fill="none"><path d="M7 8V4h10v4M7 17H5.5A2.5 2.5 0 0 1 3 14.5v-3A2.5 2.5 0 0 1 5.5 9h13a2.5 2.5 0 0 1 2.5 2.5v3a2.5 2.5 0 0 1-2.5 2.5H17M7 14h10v6H7v-6Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" /></svg>
              </button>
            </div>
          </div>

          {article.heroImage && (
            <figure class="article-hero-image">
              <img src={article.heroImage} alt="" loading="eager" decoding="async" />
            </figure>
          )}

          <section class="executive-summary" aria-labelledby="summary-heading">
            <h2 id="summary-heading">Resumen ejecutivo</h2>
            <p>{article.abstract}</p>
            {hasSummaryPoints && (
              <ol>
                {article.summaryPoints.map((point) => <li>{point}</li>)}
              </ol>
            )}
          </section>
        </header>

        {showVisualStorytelling && (
          <aside class="article-visual-rail article-visual-rail--mobile" aria-label="Resumen visual del artículo">
            <section class="visual-summary" aria-labelledby="visual-summary-title-mobile">
              <p class="rail-kicker">Resumen visual</p>
              <h2 id="visual-summary-title-mobile">{visualTitle}</h2>

              <div class="visual-map" aria-hidden="true">
                <span class="region region--one"></span>
                <span class="region region--two"></span>
                <span class="region region--three"></span>
                <span class="region region--four"></span>
                <span class="region region--five"></span>
              </div>

              <p class="visual-caption">{visualCaption}</p>

              <div class="visual-legend" aria-hidden="true">
                <span>{visualLowLabel}</span>
                <i></i><i></i><i></i><i></i>
                <span>{visualHighLabel}</span>
              </div>

              <dl class="visual-stats">
                {visualStats.map((stat) => (
                  <div>
                    <dt>{stat.value}</dt>
                    <dd>{stat.label}</dd>
                  </div>
                ))}
              </dl>
            </section>

            <section class="scroll-visual" aria-labelledby="scroll-visual-title-mobile">
              <p class="rail-kicker rail-kicker--red">Narrativa visual</p>
              <h2 id="scroll-visual-title-mobile">{narrativeVisual.title ?? 'La historia visual'}</h2>
              <p>{narrativeVisual.description ?? 'Al avanzar en la lectura, este módulo acompaña los argumentos centrales del artículo.'}</p>
              <ol>
                {narrativeSteps.map((step) => <li>{step}</li>)}
              </ol>
              <div class="reading-progress" aria-hidden="true">
                <span>Progreso de lectura</span>
                <i><b></b></i>
              </div>
            </section>
          </aside>
        )}

        <div class="article-content">
          <slot />

          {hasSources && (
            <section class="sources" aria-labelledby="sources-heading">
              <h2 id="sources-heading">Fuentes</h2>
              <ul>
                {article.sources.map((source) => (
                  <li><a href={source.url} target="_blank" rel="noopener noreferrer">{source.label}</a></li>
                ))}
              </ul>
            </section>
          )}
        </div>
      </main>

      {showVisualStorytelling && (
        <aside class="article-visual-rail article-visual-rail--desktop" aria-label="Resumen visual del artículo">
          <section class="visual-summary" aria-labelledby="visual-summary-title">
            <p class="rail-kicker">Resumen visual</p>
            <h2 id="visual-summary-title">{visualTitle}</h2>

            <div class="visual-map" aria-hidden="true">
              <span class="region region--one"></span>
              <span class="region region--two"></span>
              <span class="region region--three"></span>
              <span class="region region--four"></span>
              <span class="region region--five"></span>
            </div>

            <p class="visual-caption">{visualCaption}</p>

            <div class="visual-legend" aria-hidden="true">
              <span>{visualLowLabel}</span>
              <i></i><i></i><i></i><i></i>
              <span>{visualHighLabel}</span>
            </div>

            <dl class="visual-stats">
              {visualStats.map((stat) => (
                <div>
                  <dt>{stat.value}</dt>
                  <dd>{stat.label}</dd>
                </div>
              ))}
            </dl>
          </section>

          <section class="scroll-visual" aria-labelledby="scroll-visual-title">
            <p class="rail-kicker rail-kicker--red">Narrativa visual</p>
            <h2 id="scroll-visual-title">{narrativeVisual.title ?? 'La historia visual'}</h2>
            <p>{narrativeVisual.description ?? 'Al avanzar en la lectura, este módulo acompaña los argumentos centrales del artículo.'}</p>
            <ol>
              {narrativeSteps.map((step) => <li>{step}</li>)}
            </ol>
            <div class="reading-progress" aria-hidden="true">
              <span>Progreso de lectura</span>
              <i><b></b></i>
            </div>
          </section>
        </aside>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .article-page {
    background: #fffdfa;
    color: var(--color-ink);
    padding: clamp(2rem, 4.5vw, 4rem) 0 clamp(4rem, 8vw, 7rem);
  }

  .article-grid {
    display: grid;
    gap: clamp(2.25rem, 4.5vw, 4rem);
    align-items: start;
  }

  .article-grid--no-visual {
    max-width: 940px;
  }

  .article-main {
    min-width: 0;
  }

  .article-hero {
    border-top: 2px solid var(--color-ink);
    padding-top: 1rem;
  }

  .article-eyebrow,
  .rail-kicker {
    display: inline-flex;
    margin: 0;
    color: #f7f3ea;
    background: var(--color-primary);
    padding: 0.34rem 0.68rem;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 850;
    letter-spacing: 0.13em;
    line-height: 1;
    text-transform: uppercase;
  }

  .rail-kicker {
    display: block;
    width: fit-content;
    background: transparent;
    color: var(--color-primary);
    padding: 0;
    font-size: 0.68rem;
  }

  .rail-kicker--red {
    color: var(--color-red-700, #c51d23);
  }

  .article-hero h1 {
    max-width: 940px;
    margin: 1rem 0 1.25rem;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(2.8rem, 5.85vw, 5.85rem);
    font-weight: 600;
    letter-spacing: -0.058em;
    line-height: 0.96;
    text-wrap: balance;
  }

  .one-sentence {
    max-width: 820px;
    margin: 0;
    color: #3f454d;
    font-family: var(--font-serif);
    font-size: clamp(1.18rem, 2vw, 1.6rem);
    font-style: italic;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.34;
  }

  .article-meta-panel {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin-top: clamp(1.75rem, 4vw, 2.65rem);
    padding: 1rem 0;
  }

  .article-institution {
    display: flex;
    gap: 0.9rem;
    align-items: center;
  }

  .article-author-image {
    width: 56px;
    height: 56px;
    flex: 0 0 auto;
    display: block;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    object-fit: cover;
    background: var(--color-bg-warm);
  }

  .article-institution strong,
  .article-institution span {
    display: block;
    font-family: var(--font-sans);
  }

  .article-institution strong {
    color: var(--color-ink);
    font-size: 0.82rem;
    font-weight: 850;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .article-institution span {
    color: var(--color-text-muted);
    margin-top: 0.2rem;
    font-size: 0.86rem;
    font-weight: 650;
    line-height: 1.35;
  }

  .article-actions {
    display: inline-flex;
    gap: 0.35rem;
    align-items: center;
  }

  .article-actions button {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background: transparent;
    color: #48504f;
    cursor: pointer;
    transition: color var(--transition-fast), transform var(--transition-fast);
  }

  .article-actions button:hover,
  .article-actions button:focus-visible {
    color: var(--color-red-700, #c51d23);
    transform: translateY(-2px);
  }

  .article-actions svg {
    width: 21px;
    height: 21px;
  }

  .article-hero-image {
    border-top: 2px solid var(--color-ink);
    border-bottom: 1px solid var(--color-border);
    margin: clamp(1.25rem, 3vw, 2rem) 0 0;
    padding: clamp(1rem, 2.5vw, 1.4rem) 0;
  }

  .article-hero-image img {
    display: block;
    width: 100%;
    max-height: min(58vh, 560px);
    object-fit: cover;
  }

  .executive-summary,
  .visual-summary,
  .scroll-visual,
  .sources {
    border-top: 2px solid var(--color-ink);
    border-bottom: 1px solid var(--color-border);
  }

  .executive-summary {
    margin-top: clamp(1.35rem, 3vw, 2rem);
    padding: clamp(1.15rem, 2.6vw, 1.5rem) 0;
  }

  .executive-summary h2,
  .visual-summary h2,
  .scroll-visual h2,
  .sources h2 {
    margin: 0 0 0.75rem;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 2.25vw, 1.85rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.1;
  }

  .executive-summary p,
  .executive-summary li {
    color: var(--color-text);
    font-size: clamp(0.98rem, 1.25vw, 1.06rem);
    line-height: 1.68;
  }

  .executive-summary p {
    margin: 0;
  }

  .executive-summary ol {
    display: grid;
    gap: 0.5rem;
    margin: 1rem 0 0;
    padding-left: 1.25rem;
  }

  .article-content {
    max-width: 780px;
    min-width: 0;
    padding-top: clamp(2rem, 5vw, 4rem);
  }

  .article-grid--no-visual .article-content {
    max-width: 820px;
  }

  .article-content :global(h2) {
    margin: clamp(2rem, 5vw, 3.5rem) 0 1rem;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(1.85rem, 3.4vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.044em;
    line-height: 1.08;
  }

  .article-content :global(h3) {
    margin: 1.9rem 0 0.75rem;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .article-content :global(p),
  .article-content :global(li) {
    color: #1f252d;
    font-size: clamp(1.02rem, 1.28vw, 1.12rem);
    line-height: 1.78;
  }

  .article-content :global(p) {
    margin: 0 0 1.32rem;
  }

  .article-content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .article-content :global(blockquote) {
    border-top: 3px solid var(--color-primary);
    border-bottom: 1px solid var(--color-border);
    margin: clamp(2rem, 5vw, 3rem) 0;
    padding: 1.3rem 0;
    color: var(--color-primary);
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 2.2vw, 1.82rem);
    font-weight: 600;
    letter-spacing: -0.032em;
    line-height: 1.25;
  }

  .article-content :global(blockquote p) {
    margin: 0;
    color: inherit;
    font: inherit;
    line-height: inherit;
  }

  .sources {
    margin-top: clamp(2.5rem, 6vw, 4rem);
    padding: 1.2rem 0 1.4rem;
  }

  .sources ul {
    margin: 0;
    padding-left: 1.25rem;
  }

  .article-visual-rail {
    display: grid;
    gap: clamp(1.5rem, 3vw, 2rem);
  }

  .article-visual-rail--mobile {
    display: none;
  }

  .visual-summary,
  .scroll-visual {
    padding: clamp(1.1rem, 2.6vw, 1.45rem) 0;
  }

  .visual-summary h2,
  .scroll-visual h2 {
    margin-top: 0.58rem;
  }

  .visual-map {
    position: relative;
    aspect-ratio: 1.38;
    margin-top: 1.2rem;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  .region {
    position: absolute;
    display: block;
    clip-path: polygon(10% 18%, 80% 0, 100% 42%, 72% 100%, 0 76%);
    border: 1px solid #fffdfa;
  }

  .region--one { left: 7%; top: 15%; width: 33%; height: 31%; background: #b7d6c7; }
  .region--two { left: 33%; top: 11%; width: 34%; height: 34%; background: #7fb49d; }
  .region--three { left: 10%; top: 46%; width: 38%; height: 39%; background: #2f7e62; }
  .region--four { left: 47%; top: 42%; width: 40%; height: 38%; background: #0c5f46; }
  .region--five { right: 6%; top: 20%; width: 32%; height: 35%; background: #d33a3e; }

  .visual-caption {
    margin: 1rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.82rem;
    line-height: 1.48;
  }

  .visual-legend {
    display: grid;
    grid-template-columns: auto repeat(4, 1fr) auto;
    gap: 0.35rem;
    align-items: center;
    margin-top: 0.9rem;
  }

  .visual-legend span {
    color: var(--color-text-muted);
    font-size: 0.7rem;
    font-weight: 750;
  }

  .visual-legend i {
    height: 10px;
    display: block;
  }

  .visual-legend i:nth-of-type(1) { background: #dceee5; }
  .visual-legend i:nth-of-type(2) { background: #a5ccb9; }
  .visual-legend i:nth-of-type(3) { background: #5a9d82; }
  .visual-legend i:nth-of-type(4) { background: #0c5f46; }

  .visual-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    border-top: 1px solid var(--color-border);
    margin: 1.15rem 0 0;
    padding-top: 0.95rem;
  }

  .visual-stats div {
    min-width: 0;
  }

  .visual-stats dt {
    color: var(--color-primary);
    font-family: var(--font-serif);
    font-size: clamp(1.32rem, 2.1vw, 1.78rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .visual-stats div:nth-child(2) dt {
    color: var(--color-red-700, #c51d23);
  }

  .visual-stats dd {
    margin: 0.35rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .scroll-visual p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.88rem;
    line-height: 1.58;
  }

  .scroll-visual ol {
    display: grid;
    gap: 0;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .scroll-visual li {
    border-top: 1px solid var(--color-border);
    color: var(--color-ink);
    font-size: 0.9rem;
    font-weight: 650;
    line-height: 1.35;
    padding: 0.72rem 0;
  }

  .reading-progress {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.85rem;
    align-items: center;
    margin-top: 1.15rem;
  }

  .reading-progress span {
    color: var(--color-text-muted);
    font-size: 0.7rem;
    font-weight: 750;
  }

  .reading-progress i {
    height: 8px;
    border: 1px solid var(--color-border);
    position: relative;
  }

  .reading-progress b {
    position: absolute;
    inset: 0 38% 0 0;
    background: var(--color-primary);
  }

  @media (min-width: 1080px) {
    .article-grid:not(.article-grid--no-visual) {
      grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
    }

    .article-visual-rail--desktop {
      position: sticky;
      top: calc(var(--header-height) + 2rem);
    }
  }

  @media (max-width: 1079px) {
    .article-visual-rail--desktop {
      display: none;
    }

    .article-visual-rail--mobile {
      display: grid;
      margin-top: clamp(1.5rem, 4vw, 2.25rem);
    }
  }

  @media (max-width: 760px) {
    .article-page {
      padding-top: 1.5rem;
    }

    .article-meta-panel {
      align-items: flex-start;
    }

    .article-actions {
      width: 100%;
      justify-content: flex-start;
    }

    .visual-stats {
      grid-template-columns: 1fr;
    }
  }
</style>
