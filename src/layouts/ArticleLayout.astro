---
import BaseLayout from './BaseLayout.astro';

const { article } = Astro.props;
const date = new Intl.DateTimeFormat('es-MX', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(article.date);

const templateLabel = article.template?.replaceAll('-', ' ') ?? 'artículo';
const visualType = article.mainVisual?.type;
const hasMainVisual = Boolean(visualType && visualType !== 'none');
const hasSummaryPoints = (article.summaryPoints?.length ?? 0) > 0;
const hasSources = (article.sources?.length ?? 0) > 0;
---

<BaseLayout title={`${article.title} — Centro Economex`} description={article.abstract} ogImage={article.heroImage}>
  <article class="article-page">
    <header class="article-hero">
      <div class="container article-hero__inner">
        <p class="article-eyebrow">{templateLabel}</p>
        <h1>{article.title}</h1>
        <p class="one-sentence">{article.oneSentence}</p>

        <div class="article-meta" aria-label="Información del artículo">
          <span>{article.author}</span>
          <time datetime={article.date.toISOString()}>{date}</time>
        </div>

        {article.heroImage && (
          <img class="hero-image" src={article.heroImage} alt="" loading="eager" decoding="async" />
        )}
      </div>
    </header>

    <div class="container article-shell">
      <aside class="article-aside" aria-label="Resumen">
        <div class="summary-block">
          <p class="summary-kicker">Resumen</p>
          <p>{article.abstract}</p>
        </div>

        {hasSummaryPoints && (
          <div class="summary-block">
            <p class="summary-kicker summary-kicker--red">La idea en puntos</p>
            <ol>
              {article.summaryPoints.map((point) => <li>{point}</li>)}
            </ol>
          </div>
        )}
      </aside>

      <div class="article-content">
        {hasMainVisual && (
          <figure class="visual-placeholder">
            <p class="article-eyebrow">Elemento visual principal</p>
            <h2>{article.mainVisual?.title ?? 'Visualización del artículo'}</h2>
            <p>
              Tipo: <strong>{visualType}</strong>
              {article.mainVisual?.dataset && <> · Dataset: <code>{article.mainVisual.dataset}</code></>}
            </p>
          </figure>
        )}

        <slot />

        {hasSources && (
          <section class="sources" aria-labelledby="sources-heading">
            <h2 id="sources-heading">Fuentes</h2>
            <ul>
              {article.sources.map((source) => (
                <li><a href={source.url} target="_blank" rel="noopener noreferrer">{source.label}</a></li>
              ))}
            </ul>
          </section>
        )}
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .article-page {
    background: #fff;
    color: var(--color-ink);
  }

  .article-hero {
    background: var(--color-bg-warm);
    border-bottom: 2px solid var(--color-ink);
  }

  .article-hero__inner {
    padding-top: clamp(3rem, 7vw, 6rem);
    padding-bottom: clamp(2rem, 5vw, 4rem);
  }

  .article-eyebrow,
  .summary-kicker {
    margin: 0;
    color: var(--color-primary);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    line-height: 1;
    text-transform: uppercase;
  }

  .summary-kicker--red {
    color: var(--color-red-700, #c51d23);
  }

  .article-hero h1 {
    max-width: 980px;
    margin: 0.75rem 0 1rem;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(3rem, 7.5vw, 6.5rem);
    font-weight: 600;
    letter-spacing: -0.058em;
    line-height: 0.92;
    text-wrap: balance;
  }

  .one-sentence {
    max-width: 760px;
    margin: 0;
    color: var(--color-text);
    font-size: clamp(1.1rem, 2vw, 1.42rem);
    line-height: 1.45;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    margin-top: 1.5rem;
    text-transform: uppercase;
  }

  .hero-image {
    width: 100%;
    max-height: 520px;
    object-fit: cover;
    margin-top: clamp(1.5rem, 4vw, 3rem);
    border: 1px solid var(--color-border);
    background: #fff;
  }

  .article-shell {
    display: grid;
    gap: clamp(2rem, 5vw, 4.5rem);
    padding-top: clamp(2rem, 5vw, 4rem);
    padding-bottom: clamp(4rem, 8vw, 6rem);
  }

  .article-aside {
    display: grid;
    gap: 1.5rem;
    align-content: start;
  }

  .summary-block {
    border-top: 2px solid var(--color-ink);
    padding-top: 1rem;
  }

  .summary-block p:not(.summary-kicker),
  .summary-block li {
    color: var(--color-text);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .summary-block p:not(.summary-kicker) {
    margin: 0.8rem 0 0;
  }

  .summary-block ol {
    display: grid;
    gap: 0.75rem;
    margin: 0.9rem 0 0;
    padding-left: 1.2rem;
  }

  .article-content {
    max-width: 760px;
    min-width: 0;
  }

  .article-content :global(p),
  .article-content :global(li) {
    color: var(--color-text);
    font-size: clamp(1.05rem, 1.5vw, 1.18rem);
    line-height: 1.8;
  }

  .article-content :global(h2) {
    margin-top: clamp(2.25rem, 5vw, 4rem);
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(1.85rem, 3.3vw, 2.65rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.05;
  }

  .article-content :global(h3) {
    margin-top: 2rem;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .visual-placeholder,
  .sources {
    border-top: 2px solid var(--color-ink);
    border-bottom: 1px solid var(--color-border);
    padding: 1.25rem 0;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }

  .visual-placeholder h2,
  .sources h2 {
    margin: 0.55rem 0 0.75rem;
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.08;
  }

  .visual-placeholder code {
    font-size: 0.9rem;
    background: var(--color-bg-warm);
    border: 1px solid var(--color-border);
    padding: 0.1rem 0.35rem;
  }

  .sources {
    margin-top: clamp(2.5rem, 6vw, 4rem);
    margin-bottom: 0;
  }

  .sources ul {
    margin: 0;
    padding-left: 1.25rem;
  }

  @media (min-width: 960px) {
    .article-shell {
      grid-template-columns: minmax(220px, 280px) minmax(0, 760px);
      align-items: start;
    }

    .article-aside {
      position: sticky;
      top: calc(var(--header-height) + 2rem);
    }
  }
</style>
