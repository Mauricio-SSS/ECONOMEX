---
import BaseLayout from './BaseLayout.astro';
import ArticleVisualBlock from '../components/article/visuals/ArticleVisualBlock.astro';

const { article } = Astro.props;
const date = new Intl.DateTimeFormat('es-MX', { year: 'numeric', month: 'long', day: 'numeric' }).format(article.date);
const blocks = article.contentBlocks ?? [];
const hasBlocks = blocks.length > 0;
const authorImage = article.authorImage ?? '/images/authors/default-profile.svg';
const showRail = article.showVisualStorytelling ?? true;
const visualSummary = article.visualSummary ?? {};
const narrativeVisual = article.narrativeVisual ?? {};
const visualTitle = visualSummary.title ?? article.mainVisual?.title ?? 'Resumen visual';
const visualCaption = visualSummary.caption ?? 'Lectura sintética de los datos centrales del artículo.';
const narrativeTitle = narrativeVisual.title ?? 'Narrativa visual';
const narrativeDescription = narrativeVisual.description ?? 'Este módulo acompaña la lectura y ubica los argumentos centrales.';
const narrativeSteps = narrativeVisual.steps?.length ? narrativeVisual.steps : ['Contexto', 'Evidencia', 'Implicaciones', 'Conclusión'];
---

<BaseLayout title={`${article.title} — Centro Economex`} description={article.abstract} ogImage={article.heroImage}>
  <article class="ce-article" data-scrollytelling-root>
    <div class={`ce-article__grid container ${showRail ? '' : 'ce-article__grid--single'}`}>
      <main class="ce-article__main">
        <header class="ce-article__hero">
          <p class="ce-kicker">{article.template?.replaceAll('-', ' ') ?? 'artículo'}</p>
          <h1>{article.title}</h1>
          <p class="ce-dek">{article.oneSentence}</p>
          <div class="ce-meta">
            <div class="ce-author"><img src={authorImage} alt="" /><div><strong>{article.author ?? 'Centro Economex'}</strong><span>Publicado el {date} • {article.readTime ?? '12 min de lectura'}</span></div></div>
            <div class="ce-actions" aria-label="Acciones del artículo"><button type="button" aria-label="Compartir">↗</button><button type="button" aria-label="Guardar">□</button><button type="button" aria-label="Imprimir">▣</button></div>
          </div>
          {article.heroImage && <figure class="ce-hero-image"><img src={article.heroImage} alt="" loading="eager" decoding="async" /></figure>}
          <section class="ce-summary"><h2>Resumen ejecutivo</h2><p>{article.abstract}</p>{article.summaryPoints?.length > 0 && <ol>{article.summaryPoints.map((point) => <li>{point}</li>)}</ol>}</section>
        </header>

        {showRail && <aside class="ce-rail ce-rail--mobile" aria-label="Resumen visual del artículo"><Fragment set:html={''} /><section class="ce-visual-summary"><p class="ce-kicker ce-kicker--green">Resumen visual</p><h2>{visualTitle}</h2><p>{visualCaption}</p></section><details class="ce-story" open><summary><span><span class="ce-kicker ce-kicker--red">Narrativa visual</span><b>{narrativeTitle}</b><span class="ce-progress"><span data-reading-progress-label>Progreso de lectura</span><i><em data-reading-progress-bar></em></i></span></span><small aria-hidden="true"></small></summary><div><p>{narrativeDescription}</p><ol>{narrativeSteps.map((step, index) => <li data-scrolly-step data-step-index={index}>{step}</li>)}</ol></div></details></aside>}

        <div class="ce-content" data-article-content>
          {hasBlocks ? blocks.map((block) => <>
            {(block.type === 'paragraph' || !block.type) && <section class="ce-block">{block.heading && <h2>{block.heading}</h2>}{block.text && <div class="ce-block-text">{block.text}</div>}</section>}
            {block.type === 'visual' && <ArticleVisualBlock block={{ ...block, type: block.visualType ?? 'data-card' }} />}
            {block.type === 'image' && <figure class="ce-inline-image">{block.title && <h3>{block.title}</h3>}{block.image && <img src={block.image} alt={block.alt ?? ''} loading="lazy" decoding="async" />}{(block.caption || block.source) && <figcaption>{block.caption}{block.source && <span> Fuente: {block.source}</span>}</figcaption>}</figure>}
            {block.type === 'quote' && <blockquote><p>{block.quote}</p>{block.attribution && <cite>{block.attribution}</cite>}</blockquote>}
            {block.type === 'stat' && <aside class="ce-stat">{block.kicker && <p>{block.kicker}</p>}<strong>{block.value}</strong><span>{block.label}</span></aside>}
          </>) : <slot />}
          {article.sources?.length > 0 && <section class="ce-sources"><h2>Fuentes</h2><ul>{article.sources.map((source) => <li><a href={source.url} target="_blank" rel="noopener noreferrer">{source.label}</a></li>)}</ul></section>}
        </div>
      </main>

      {showRail && <aside class="ce-rail ce-rail--desktop" aria-label="Resumen visual del artículo"><section class="ce-visual-summary"><p class="ce-kicker ce-kicker--green">Resumen visual</p><h2>{visualTitle}</h2><p>{visualCaption}</p></section><details class="ce-story" open><summary><span><span class="ce-kicker ce-kicker--red">Narrativa visual</span><b>{narrativeTitle}</b><span class="ce-progress"><span data-reading-progress-label>Progreso de lectura</span><i><em data-reading-progress-bar></em></i></span></span><small aria-hidden="true"></small></summary><div><p>{narrativeDescription}</p><ol>{narrativeSteps.map((step, index) => <li data-scrolly-step data-step-index={index}>{step}</li>)}</ol></div></details></aside>}
    </div>
  </article>
</BaseLayout>

<style>
.ce-article{background:#fffdfa;color:var(--color-ink);padding:clamp(2rem,4vw,4rem) 0 6rem}.ce-article__grid{display:grid;gap:clamp(2rem,4vw,4rem)}.ce-article__grid--single{max-width:960px}.ce-article__hero{border-top:2px solid var(--color-ink);padding-top:1rem}.ce-kicker{display:inline-flex;margin:0;background:var(--color-primary);color:#f7f3ea;padding:.35rem .7rem;font-size:.68rem;font-weight:850;letter-spacing:.13em;text-transform:uppercase}.ce-kicker--green,.ce-kicker--red{background:transparent;padding:0}.ce-kicker--green{color:var(--color-primary)}.ce-kicker--red{color:var(--color-red-700,#c51d23)}h1{max-width:940px;margin:1rem 0 1.25rem;font-family:var(--font-serif);font-size:clamp(2.7rem,5.8vw,5.8rem);font-weight:600;letter-spacing:-.058em;line-height:.97}.ce-dek{max-width:820px;margin:0;color:#3f454d;font-family:var(--font-serif);font-size:clamp(1.18rem,2vw,1.6rem);font-style:italic;line-height:1.35}.ce-meta{display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap;border-top:1px solid var(--color-border);border-bottom:1px solid var(--color-border);margin-top:2rem;padding:1rem 0}.ce-author{display:flex;gap:.9rem;align-items:center}.ce-author img{width:56px;height:56px;border-radius:50%;object-fit:cover;border:1px solid var(--color-border)}.ce-author strong,.ce-author span{display:block;font-family:var(--font-sans)}.ce-author strong{font-size:.82rem;font-weight:850;letter-spacing:.09em;text-transform:uppercase}.ce-author span{color:var(--color-text-muted);font-size:.86rem}.ce-actions button{width:36px;height:36px;border:0;background:transparent;color:#48504f;cursor:pointer}.ce-hero-image,.ce-inline-image{border-top:2px solid var(--color-ink);border-bottom:1px solid var(--color-border);margin:clamp(1.4rem,3vw,2rem) 0;padding:clamp(1rem,2vw,1.4rem) 0}.ce-hero-image img,.ce-inline-image img{display:block;width:100%;max-height:min(58vh,560px);object-fit:cover}.ce-inline-image h3{margin:0 0 .9rem;font-family:var(--font-serif);font-size:clamp(1.35rem,2.4vw,2rem);letter-spacing:-.035em}.ce-inline-image figcaption{margin-top:.75rem;color:var(--color-text-muted);font-size:.78rem;line-height:1.5}.ce-inline-image figcaption span{color:var(--color-primary);font-weight:750}.ce-summary,.ce-visual-summary,.ce-story,.ce-sources{border-top:2px solid var(--color-ink);border-bottom:1px solid var(--color-border);padding:1.25rem 0}.ce-summary{margin-top:2rem}.ce-summary h2,.ce-visual-summary h2,.ce-sources h2{font-family:var(--font-serif);font-size:clamp(1.35rem,2.25vw,1.85rem);letter-spacing:-.035em}.ce-content{max-width:780px;padding-top:clamp(2rem,5vw,4rem)}.ce-content h2{font-family:var(--font-serif);font-size:clamp(1.85rem,3.4vw,3rem);letter-spacing:-.044em;line-height:1.1}.ce-content p,.ce-content li,.ce-block-text{font-size:clamp(1.02rem,1.28vw,1.12rem);line-height:1.78;color:#1f252d}.ce-block-text{white-space:pre-line}.ce-content blockquote{border-top:3px solid var(--color-primary);border-bottom:1px solid var(--color-border);margin:2.5rem 0;padding:1.3rem 0;color:var(--color-primary);font-family:var(--font-serif);font-size:clamp(1.3rem,2.2vw,1.82rem);line-height:1.25}.ce-content blockquote p{color:inherit;font:inherit}.ce-content cite{display:block;margin-top:.9rem;color:var(--color-text-muted);font-family:var(--font-sans);font-size:.78rem;font-style:normal;font-weight:800;letter-spacing:.1em;text-transform:uppercase}.ce-stat{border-top:2px solid var(--color-ink);border-bottom:1px solid var(--color-border);margin:2rem 0;padding:1.25rem 0}.ce-stat p{margin:0 0 .55rem;color:var(--color-red-700,#c51d23);font-size:.68rem;font-weight:850;letter-spacing:.12em;text-transform:uppercase}.ce-stat strong{display:block;color:var(--color-primary);font-family:var(--font-serif);font-size:clamp(2.5rem,6vw,4.4rem);letter-spacing:-.06em;line-height:.95}.ce-stat span{display:block;margin-top:.8rem;color:var(--color-text-muted)}.ce-rail{display:grid;gap:1.4rem;align-content:start}.ce-rail--mobile{display:none}.ce-visual-summary{background:#fffdfa}.ce-story{background:#fffdfa}.ce-story summary{display:flex;justify-content:space-between;gap:1rem;cursor:pointer;list-style:none}.ce-story summary::-webkit-details-marker{display:none}.ce-story b{display:block;margin:.6rem 0 .2rem;font-family:var(--font-serif);font-size:clamp(1.35rem,2.25vw,1.85rem);letter-spacing:-.035em}.ce-story small{width:28px;height:28px;border:1px solid var(--color-border);display:grid;place-items:center}.ce-story small:before{content:'+'}.ce-story[open] small:before{content:'–'}.ce-story ol{list-style:none;margin:1rem 0 0;padding:0}.ce-story li{border-top:1px solid var(--color-border);padding:.72rem 0;cursor:pointer}.ce-story li.is-active{color:var(--color-red-700,#c51d23);padding-left:.6rem}.ce-progress{display:grid;grid-template-columns:auto 1fr;gap:.75rem;align-items:center;margin-top:.85rem}.ce-progress span{font-size:.7rem;color:var(--color-text-muted);font-family:var(--font-sans)}.ce-progress i{height:8px;border:1px solid var(--color-border);position:relative;min-width:80px}.ce-progress em{position:absolute;inset:0 auto 0 0;width:0;background:var(--color-primary)}@media(min-width:1080px){.ce-article__grid:not(.ce-article__grid--single){grid-template-columns:minmax(0,1fr) minmax(280px,360px)}.ce-rail--desktop{position:sticky;top:calc(var(--header-height) + 1.25rem);max-height:calc(100vh - var(--header-height) - 2.5rem);overflow:auto}}@media(max-width:1079px){.ce-rail--desktop{display:none}.ce-rail--mobile{display:grid;margin-top:2rem}.ce-rail--mobile .ce-story{position:sticky;top:calc(var(--header-height) + .5rem);z-index:20;max-height:calc(100vh - var(--header-height) - 1rem);overflow:auto;box-shadow:0 10px 18px rgba(18,24,33,.05)}}@media(max-width:760px){.ce-actions{width:100%}.ce-summary ol{padding-left:1.25rem}}
</style>

<script is:inline>
(()=>{const clamp=(v,min,max)=>Math.min(Math.max(v,min),max);document.querySelectorAll('[data-scrollytelling-root]').forEach(root=>{const article=root.querySelector('[data-article-content]');const bars=[...root.querySelectorAll('[data-reading-progress-bar]')];const labels=[...root.querySelectorAll('[data-reading-progress-label]')];const steps=[...root.querySelectorAll('[data-scrolly-step]')];if(!article)return;let sections=[...article.querySelectorAll('h2,h3')].filter(s=>s.textContent?.trim());if(!sections.length)sections=[...article.querySelectorAll('p,figure,blockquote,aside')].filter(s=>s.textContent?.trim());steps.forEach(item=>{const index=Number(item.dataset.stepIndex||0);item.tabIndex=0;item.addEventListener('click',()=>sections[Math.min(index,sections.length-1)]?.scrollIntoView({behavior:'smooth',block:'start'}))});const update=()=>{const rect=article.getBoundingClientRect();const top=scrollY+rect.top;const bottom=top+article.scrollHeight;const line=scrollY+innerHeight*.38;const pct=Math.round(clamp((line-top)/Math.max(bottom-top,1),0,1)*100);bars.forEach(bar=>bar.style.width=`${pct}%`);labels.forEach(label=>label.textContent=`Progreso de lectura ${pct}%`);let active=0;sections.forEach((section,index)=>{if(scrollY+section.getBoundingClientRect().top<=line)active=index});steps.forEach((step,index)=>step.classList.toggle('is-active',index===Math.min(active,steps.length-1)))};update();addEventListener('scroll',update,{passive:true});addEventListener('resize',update)})})();
</script>
